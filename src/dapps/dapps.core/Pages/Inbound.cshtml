@page
@model InboundModel
@{
    ViewData["Title"] = $"DAPPS - inbound feed (@{Model.Options.Callsign})";
}

<header class="app-header">
    <span class="brand">
        <span class="dot"></span>
        DAPPS
        <span class="callsign">@Model.Options.Callsign</span>
        <span style="color: var(--text-muted); font-weight: 500; margin-left: 0.4rem;">→ inbound feed</span>
    </span>
    <span class="spacer"></span>
    <a href="/">dashboard</a>
    <a href="/IHave">ihave</a>
    <a href="/Streams">streams</a>
    <a href="/Transmissions">audit</a>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a href="/Logout" class="signout">sign out</a>
    }
</header>

<main>
    <h2>Live inbound stream
        <span id="sse-status" class="pill">connecting…</span>
    </h2>
    <p class="muted-inline">
        Server-sent events from <code>/Events/inbound</code>. Every message landed by the inbox layer
        (after persist + MQTT inject) appears here in real time. Newest first. Click a row to fetch
        the payload preview from <code>/Events/payload/&lt;id&gt;</code>; reload the page to clear.
    </p>

    <div class="inbound-filters" style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: end; margin: 0.75rem 0 0.5rem;">
        <div>
            <label for="filter-app" style="display:block; font-size: 0.8rem; color: var(--text-muted);">App</label>
            <input id="filter-app" type="text" placeholder="e.g. mail" style="width: 12rem;" />
        </div>
        <div>
            <label for="filter-callsign" style="display:block; font-size: 0.8rem; color: var(--text-muted);">Source callsign</label>
            <input id="filter-callsign" type="text" placeholder="e.g. M0LTE" style="width: 12rem;" />
        </div>
        <div>
            <label for="filter-dest" style="display:block; font-size: 0.8rem; color: var(--text-muted);">Destination</label>
            <input id="filter-dest" type="text" placeholder="substring" style="width: 12rem;" />
        </div>
        <button type="button" id="filter-clear" style="height: 2rem;">clear</button>
        <span class="muted-inline" id="filter-summary">showing all rows</span>
    </div>

    <table id="inbound-table">
        <thead>
            <tr>
                <th style="width: 11rem;">Received (UTC)</th>
                <th style="width: 7rem;">Id</th>
                <th style="width: 9rem;">Source</th>
                <th>Destination</th>
                <th class="numeric" style="width: 6rem;">Bytes</th>
                <th class="numeric" style="width: 5rem;">TTL</th>
            </tr>
        </thead>
        <tbody id="inbound-body">
            <tr><td colspan="6" class="muted" style="text-align: center;">waiting for events…</td></tr>
        </tbody>
    </table>

    <p class="muted-inline" style="margin-top: 1rem;">
        Showing the last <span id="inbound-count">0</span> event(s) since this tab opened.
    </p>
</main>

<style>
    tr.inbound-row { cursor: pointer; }
    tr.inbound-row.selected td { background: var(--row-selected, #1f2933); }
    tr.payload-row td { background: var(--row-payload, #11161c); }
    tr.payload-row pre {
        max-height: 24rem; overflow: auto; margin: 0; padding: 0.5rem;
        font-size: 0.78rem; white-space: pre-wrap; word-break: break-all;
    }
    .payload-meta { font-size: 0.78rem; color: var(--text-muted); margin-bottom: 0.4rem; }
    .payload-tabs button {
        font-size: 0.75rem; padding: 0.15rem 0.5rem; margin-right: 0.25rem;
        border-radius: 4px; cursor: pointer;
    }
    .payload-tabs button.active { background: var(--accent, #2d6cdf); color: white; }
</style>

<script>
    (function () {
        const tbody = document.getElementById('inbound-body');
        const status = document.getElementById('sse-status');
        const counter = document.getElementById('inbound-count');
        const fApp = document.getElementById('filter-app');
        const fCall = document.getElementById('filter-callsign');
        const fDest = document.getElementById('filter-dest');
        const fSummary = document.getElementById('filter-summary');
        const fClear = document.getElementById('filter-clear');
        let count = 0;
        let cleared = false;

        const fmtAt = (iso) => {
            try { return new Date(iso).toISOString().replace('T', ' ').substring(0, 19); }
            catch { return iso ?? '-'; }
        };
        const escape = (s) => String(s ?? '').replace(/[&<>"']/g, c =>
            ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

        // Pull the app slug ('foo' from 'foo@@CALL-SSID') for filter
        // matches without forcing the operator to type the @@callsign.
        const appOf = (dest) => {
            const at = String(dest ?? '').indexOf('@@');
            return at > 0 ? String(dest).substring(0, at) : String(dest ?? '');
        };

        const matchesFilter = (row) => {
            const app = (fApp.value || '').trim().toLowerCase();
            const call = (fCall.value || '').trim().toLowerCase();
            const dest = (fDest.value || '').trim().toLowerCase();
            if (app && !appOf(row.dataset.dest).toLowerCase().includes(app)) return false;
            if (call && !row.dataset.src.toLowerCase().includes(call)) return false;
            if (dest && !row.dataset.dest.toLowerCase().includes(dest)) return false;
            return true;
        };

        const applyFilters = () => {
            let visible = 0;
            for (const tr of tbody.querySelectorAll('tr.inbound-row')) {
                const show = matchesFilter(tr);
                tr.style.display = show ? '' : 'none';
                // Hide the expanded payload row alongside its parent so a
                // collapsed parent doesn't leave an orphan preview behind.
                const next = tr.nextElementSibling;
                if (next && next.classList.contains('payload-row')) {
                    next.style.display = show ? '' : 'none';
                }
                if (show) visible += 1;
            }
            const anyFilter = (fApp.value || fCall.value || fDest.value).trim().length > 0;
            fSummary.textContent = anyFilter
                ? `showing ${visible} of ${tbody.querySelectorAll('tr.inbound-row').length} rows`
                : 'showing all rows';
        };

        fApp.addEventListener('input', applyFilters);
        fCall.addEventListener('input', applyFilters);
        fDest.addEventListener('input', applyFilters);
        fClear.addEventListener('click', () => {
            fApp.value = ''; fCall.value = ''; fDest.value = '';
            applyFilters();
        });

        const togglePayload = async (row) => {
            const id = row.dataset.id;
            const next = row.nextElementSibling;
            if (next && next.classList.contains('payload-row') && next.dataset.id === id) {
                next.remove();
                row.classList.remove('selected');
                return;
            }
            // Close any other open preview - at most one expanded row at
            // a time keeps the table readable on a busy node.
            tbody.querySelectorAll('tr.payload-row').forEach(r => r.remove());
            tbody.querySelectorAll('tr.inbound-row.selected').forEach(r => r.classList.remove('selected'));

            row.classList.add('selected');
            const tr = document.createElement('tr');
            tr.className = 'payload-row';
            tr.dataset.id = id;
            tr.innerHTML = `<td colspan="6"><div class="payload-meta">loading payload for <code>${escape(id)}</code>…</div></td>`;
            row.parentNode.insertBefore(tr, row.nextSibling);

            try {
                const res = await fetch('/Events/payload/' + encodeURIComponent(id), { credentials: 'same-origin' });
                if (res.status === 404) {
                    tr.innerHTML = `<td colspan="6"><div class="payload-meta">payload for <code>${escape(id)}</code> not found - row may have been swept</div></td>`;
                    return;
                }
                if (!res.ok) {
                    tr.innerHTML = `<td colspan="6"><div class="payload-meta">payload fetch failed: HTTP ${res.status}</div></td>`;
                    return;
                }
                const p = await res.json();
                const meta = `${p.byteLength} byte(s)`
                    + (p.truncated ? ' - preview truncated' : '')
                    + (p.textValid ? '' : ' - not valid UTF-8, showing hex')
                    + ` · src <code>${escape(p.sourceCallsign)}</code>`
                    + ` · dst <code>${escape(p.destination)}</code>`;
                const showText = p.textValid;
                tr.innerHTML =
                    `<td colspan="6">
                        <div class="payload-meta">${meta}</div>
                        <div class="payload-tabs">
                            <button type="button" data-mode="text" class="${showText ? 'active' : ''}" ${showText ? '' : 'disabled'}>text</button>
                            <button type="button" data-mode="hex" class="${showText ? '' : 'active'}">hex</button>
                        </div>
                        <pre data-mode="text" style="${showText ? '' : 'display:none;'}">${escape(p.text || '')}</pre>
                        <pre data-mode="hex" style="${showText ? 'display:none;' : ''}">${escape(p.hex || '')}</pre>
                    </td>`;
                tr.querySelectorAll('.payload-tabs button').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const mode = btn.dataset.mode;
                        tr.querySelectorAll('.payload-tabs button').forEach(b => b.classList.toggle('active', b === btn));
                        tr.querySelectorAll('pre').forEach(pre => {
                            pre.style.display = pre.dataset.mode === mode ? '' : 'none';
                        });
                    });
                });
            } catch (e) {
                tr.innerHTML = `<td colspan="6"><div class="payload-meta">payload fetch failed: ${escape(e.message ?? e)}</div></td>`;
            }
        };

        const es = new EventSource('/Events/inbound');
        es.onopen = () => {
            status.textContent = 'live';
            status.className = 'pill ok';
        };
        es.onerror = () => {
            // EventSource auto-reconnects; surface the gap.
            status.textContent = 'reconnecting';
            status.className = 'pill warn';
        };
        es.addEventListener('inbound', (ev) => {
            if (!cleared) { tbody.innerHTML = ''; cleared = true; }
            try {
                const d = JSON.parse(ev.data);
                const row = document.createElement('tr');
                row.className = 'inbound-row';
                row.dataset.id = d.id;
                row.dataset.src = d.sourceCallsign ?? '';
                row.dataset.dest = d.destination ?? '';
                row.innerHTML =
                    '<td>' + escape(fmtAt(d.receivedAt)) + '</td>' +
                    '<td><code>' + escape(d.id) + '</code></td>' +
                    '<td>' + escape(d.sourceCallsign) + '</td>' +
                    '<td>' + escape(d.destination) + '</td>' +
                    '<td class="numeric">' + escape(d.payloadLength) + '</td>' +
                    '<td class="numeric">' + (d.ttl == null ? '-' : escape(d.ttl)) + '</td>';
                row.addEventListener('click', () => togglePayload(row));
                if (!matchesFilter(row)) row.style.display = 'none';
                tbody.insertBefore(row, tbody.firstChild);
                count += 1;
                counter.textContent = count;
                // Cap the visible rows so the DOM doesn't grow unbounded
                // on a busy node. Drop the payload-row siblings too.
                while (tbody.querySelectorAll('tr.inbound-row').length > 500) {
                    const last = [...tbody.querySelectorAll('tr.inbound-row')].pop();
                    const sib = last.nextElementSibling;
                    if (sib && sib.classList.contains('payload-row')) sib.remove();
                    last.remove();
                }
                applyFilters();
            } catch (e) {
                console.error('inbound parse failed', e);
            }
        });
    })();
</script>
