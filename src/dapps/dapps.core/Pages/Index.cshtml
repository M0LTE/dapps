</table>

<script>
    // Poll /Events/queue every 5s and rerender just the two
    // <tbody>s + the count pills. No full-page reload — keeps
    // scroll position, open <details>, focus, etc.
    (function () {
        const fmtAge = (s) => {
            if (s < 90) return `${s}s`;
            const m = Math.floor(s / 60);
            if (m < 90) return `${m}m`;
            const h = Math.floor(s / 3600);
            if (h < 36) return `${h}h`;
            return `${Math.floor(s / 86400)}d`;
        };
        const escape = (s) => String(s).replace(/[&<>"']/g, c =>
            ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
        const render = (rows, cols) => {
            if (!rows.length) {
                return `<tr><td colspan="${cols.length}" class="muted" style="text-align:center;">empty</td></tr>`;
            }
            return rows.map(r => '<tr>' + cols.map(c => c(r)).join('') + '</tr>').join('');
        };
        const outboundCols = [
            r => `<td><code>${escape(r.id)}</code></td>`,
            r => `<td><code>${escape(r.destination)}</code></td>`,
            r => `<td><code>${escape(r.sourceCallsign)}</code></td>`,
            r => `<td class="numeric">${r.bytes}</td>`,
            r => `<td class="numeric">${r.ttl ?? '—'}</td>`,
            r => `<td class="muted">${fmtAge(r.ageSeconds)}</td>`,
        ];
        const inboxCols = [
            r => `<td><code>${escape(r.id)}</code></td>`,
            r => `<td><code>${escape(r.app)}</code></td>`,
            r => `<td><code>${escape(r.sourceCallsign)}</code></td>`,
            r => `<td class="numeric">${r.bytes}</td>`,
            r => `<td class="numeric">${r.ttl ?? '—'}</td>`,
            r => `<td class="muted">${fmtAge(r.ageSeconds)}</td>`,
        ];
        async function poll() {
            try {
                const res = await fetch('/Events/queue', { credentials: 'same-origin' });
                if (!res.ok) return;
                const d = await res.json();
                document.getElementById('outbound-body').innerHTML = render(d.outbound, outboundCols);
                document.getElementById('inbox-body').innerHTML = render(d.localInbox, inboxCols);
                const oc = document.getElementById('outbound-count');
                oc.textContent = d.outbound.length;
                oc.className = 'pill' + (d.outbound.length ? ' warn' : '');
                const ic = document.getElementById('inbox-count');
                ic.textContent = d.localInbox.length;
                ic.className = 'pill' + (d.localInbox.length ? ' info' : '');
            } catch { /* swallow; try again next tick */ }
        }
        setInterval(poll, 5000);
    })();
</script>

