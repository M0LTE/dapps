@inject SystemOptionsBackedTxGate TxGate
@{
    var title = ViewData["Title"] as string ?? "DAPPS";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    @{
        var refreshSeconds = ViewData["RefreshSeconds"] as int?;
        if (refreshSeconds is > 0)
        {
            <meta http-equiv="refresh" content="@refreshSeconds" />
        }
    }
    <title>@title</title>
    <style>
        :root {
            --bg: #f8fafc;
            --surface: #ffffff;
            --surface-2: #f1f5f9;
            --border: #e2e8f0;
            --border-strong: #cbd5e1;
            --text: #0f172a;
            --text-muted: #64748b;
            --text-dim: #94a3b8;
            --accent: #2563eb;
            --accent-hover: #1d4ed8;
            --accent-soft: #dbeafe;
            --ok: #16a34a;
            --ok-soft: #dcfce7;
            --warn: #d97706;
            --warn-soft: #fef3c7;
            --err: #dc2626;
            --err-soft: #fee2e2;
            --info: #0891b2;
            --info-soft: #cffafe;
            --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04), 0 1px 1px rgba(15, 23, 42, 0.04);
            --shadow: 0 4px 12px rgba(15, 23, 42, 0.06), 0 1px 2px rgba(15, 23, 42, 0.04);
            --radius: 8px;
            --radius-sm: 5px;
            --font-ui: ui-sans-serif, system-ui, -apple-system, "Segoe UI Variable", "Segoe UI", Roboto, sans-serif;
            --font-mono: ui-monospace, "SF Mono", "Cascadia Mono", Menlo, Consolas, monospace;
        }
        @@media (prefers-color-scheme: dark) {
            :root {
                --bg: #0b1220;
                --surface: #111827;
                --surface-2: #1e293b;
                --border: #1f2937;
                --border-strong: #334155;
                --text: #e5e7eb;
                --text-muted: #94a3b8;
                --text-dim: #64748b;
                --accent: #60a5fa;
                --accent-hover: #93c5fd;
                --accent-soft: #1e3a8a;
                --ok: #4ade80;
                --ok-soft: #14532d;
                --warn: #fbbf24;
                --warn-soft: #78350f;
                --err: #f87171;
                --err-soft: #7f1d1d;
                --info: #22d3ee;
                --info-soft: #155e75;
                --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
                --shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
            }
        }

        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body {
            font-family: var(--font-ui);
            background: var(--bg);
            color: var(--text);
            line-height: 1.5;
            font-size: 14px;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
        }

        /* ── Header ─────────────────────────────────────────────── */
        .app-header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0.85rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            position: sticky; top: 0; z-index: 10;
            backdrop-filter: saturate(160%) blur(8px);
            background: color-mix(in srgb, var(--surface) 92%, transparent);
        }
        .app-header .brand {
            display: flex; align-items: baseline; gap: 0.5rem;
            font-weight: 600; font-size: 1.05rem; letter-spacing: -0.01em;
        }
        .app-header .brand .dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--ok); box-shadow: 0 0 0 3px color-mix(in srgb, var(--ok) 25%, transparent);
            display: inline-block; align-self: center;
        }
        .app-header .brand .callsign {
            font-family: var(--font-mono); font-weight: 600;
            color: var(--accent);
            background: var(--accent-soft);
            padding: 0.1rem 0.5rem; border-radius: var(--radius-sm);
            font-size: 0.95rem;
        }
        .app-header .spacer { flex: 1; }
        .app-header a {
            color: var(--text-muted); text-decoration: none;
            font-size: 0.85rem; padding: 0.3rem 0.65rem; border-radius: var(--radius-sm);
        }
        .app-header a:hover { color: var(--text); background: var(--surface-2); }

        /* ── Page layout ────────────────────────────────────────── */
        main { max-width: 1280px; margin: 0 auto; padding: 1.25rem 1.5rem 3rem; }

        h1 { display: none; }   /* page title now lives in the header */
        h2 {
            font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em;
            color: var(--text-muted); font-weight: 600;
            margin: 1.75rem 0 0.65rem; padding: 0;
            border: none;
        }
        h2:first-of-type { margin-top: 0.5rem; }
        h2 .badge { font-size: 0.7rem; vertical-align: middle; }

        /* ── KPI grid ───────────────────────────────────────────── */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 0.75rem;
        }
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 0.85rem 1rem;
            box-shadow: var(--shadow-sm);
            transition: box-shadow 120ms;
        }
        .card:hover { box-shadow: var(--shadow); }
        .card .label {
            font-size: 0.7rem; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.07em; font-weight: 600;
        }
        .card .value {
            font-size: 1.4rem; font-weight: 600;
            margin-top: 0.3rem; font-variant-numeric: tabular-nums;
            color: var(--text); letter-spacing: -0.01em;
            display: flex; align-items: center; gap: 0.4rem; flex-wrap: nowrap;
            min-width: 0; overflow: hidden; text-overflow: ellipsis;
        }
        .card .value .dot { width: 8px; height: 8px; flex-shrink: 0; }
        .card .value.mono {
            font-family: var(--font-mono); font-size: 1.05rem; font-weight: 500;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .card .caption {
            font-size: 0.72rem; color: var(--text-dim); margin-top: 0.25rem;
            line-height: 1.35;
        }

        /* ── Tables ─────────────────────────────────────────────── */
        table {
            width: 100%; border-collapse: separate; border-spacing: 0;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); overflow: hidden;
            box-shadow: var(--shadow-sm);
            font-size: 0.875rem;
        }
        thead th {
            background: var(--surface-2);
            color: var(--text-muted);
            font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em;
            font-weight: 600; text-align: left;
            padding: 0.55rem 0.85rem;
            border-bottom: 1px solid var(--border);
        }
        tbody td {
            padding: 0.5rem 0.85rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }
        tbody tr:last-child td { border-bottom: none; }
        tbody tr:hover { background: color-mix(in srgb, var(--surface-2) 60%, transparent); }
        td.numeric, th.numeric { text-align: right; font-variant-numeric: tabular-nums; }

        /* ── Status pills / dots ───────────────────────────────── */
        .pill {
            display: inline-flex; align-items: center; gap: 0.3rem;
            padding: 0.1rem 0.5rem; border-radius: 999px;
            font-size: 0.72rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.04em;
            background: var(--surface-2); color: var(--text-muted);
        }
        .pill.ok { background: var(--ok-soft); color: var(--ok); }
        .pill.warn { background: var(--warn-soft); color: var(--warn); }
        .pill.err { background: var(--err-soft); color: var(--err); }
        .pill.info { background: var(--info-soft); color: var(--info); }
        .pill.accent { background: var(--accent-soft); color: var(--accent); }
        .dot { width: 8px; height: 8px; display: inline-block; border-radius: 50%; }
        .dot.ok { background: var(--ok); }
        .dot.warn { background: var(--warn); }
        .dot.err { background: var(--err); }
        .dot.live {
            background: var(--ok);
            animation: pulse 1.8s ease-in-out infinite;
        }
        @@keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--ok) 60%, transparent); }
            50% { box-shadow: 0 0 0 6px color-mix(in srgb, var(--ok) 0%, transparent); }
        }

        /* ── Banners ────────────────────────────────────────────── */
        .ok-banner, .err-banner {
            padding: 0.65rem 0.9rem; border-radius: var(--radius);
            margin: 0 0 1rem; font-size: 0.875rem;
            border: 1px solid transparent;
        }
        .ok-banner { background: var(--ok-soft); border-color: color-mix(in srgb, var(--ok) 25%, transparent); color: var(--ok); }
        .err-banner { background: var(--err-soft); border-color: color-mix(in srgb, var(--err) 25%, transparent); color: var(--err); }

        /* ── TX kill-switch banner ─────────────────────────────── */
        .tx-stop-banner {
            position: sticky; top: 0; z-index: 20;
            background: var(--err); color: white;
            padding: 0.6rem 1.5rem;
            display: flex; align-items: center; gap: 1rem;
            font-size: 0.9rem; font-weight: 600;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
            animation: tx-stop-pulse 2s ease-in-out infinite;
        }
        .tx-stop-banner .tx-stop-icon {
            display: inline-block; width: 1.2rem; height: 1.2rem;
            border-radius: 50%; background: white;
            position: relative; flex-shrink: 0;
        }
        .tx-stop-banner .tx-stop-icon::after {
            content: ""; position: absolute;
            inset: 0.25rem; background: var(--err);
            border-radius: 2px;
        }
        .tx-stop-banner .tx-stop-reason {
            opacity: 0.9; font-weight: 400;
        }
        .tx-stop-banner .spacer { flex: 1; }
        .tx-stop-banner form { margin: 0; }
        .tx-stop-banner button {
            background: white; color: var(--err);
            border: 0; border-radius: var(--radius-sm);
            padding: 0.35rem 0.85rem;
            font: inherit; font-weight: 600; font-size: 0.85rem;
            cursor: pointer;
        }
        .tx-stop-banner button:hover { background: #fee; }
        @@keyframes tx-stop-pulse {
            0%, 100% { box-shadow: 0 2px 8px rgba(0,0,0,0.2), 0 0 0 0 color-mix(in srgb, var(--err) 60%, transparent); }
            50%      { box-shadow: 0 2px 8px rgba(0,0,0,0.2), 0 0 0 6px color-mix(in srgb, var(--err) 0%, transparent); }
        }
        /* Inline TX-stop button on every page header (when TX is on).
           Single-click stop with no confirmation - this is a safety
           control and the operator wants it to be fast. Resume goes
           via the banner, also one click. */
        form.tx-stop-form { margin: 0; padding: 0; }
        button.tx-stop-btn {
            background: var(--err); color: white;
            border: 1px solid var(--err);
            border-radius: var(--radius-sm);
            padding: 0.25rem 0.7rem;
            font: inherit; font-weight: 600; font-size: 0.78rem;
            letter-spacing: 0.05em; text-transform: uppercase;
            cursor: pointer;
        }
        button.tx-stop-btn:hover { background: #b91c1c; border-color: #b91c1c; }
        /* Floating STOP control - visible from every page when TX is
           currently allowed, so an operator can kill TX in one click
           regardless of where they are. Sits above the page header
           sticky strip. */
        .tx-stop-floating {
            position: fixed; top: 0.55rem; right: 1rem; z-index: 30;
        }

        /* ── Code / mono ────────────────────────────────────────── */
        code {
            font-family: var(--font-mono); font-size: 0.85em;
            background: var(--surface-2); color: var(--text);
            padding: 0.08rem 0.35rem; border-radius: 4px;
        }
        td code { background: transparent; padding: 0; color: var(--accent); }
        .muted { color: var(--text-muted); }
        p.muted-inline { color: var(--text-muted); font-size: 0.85rem;
                         margin: 0.25rem 0 0.6rem; padding: 0; border: 0; background: none; text-align: left; }
        h2 .pill { font-size: 0.7rem; vertical-align: middle; margin-left: 0.4rem; }
        h3.subhead {
            font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em;
            color: var(--text-muted); font-weight: 600;
            margin: 1.2rem 0 0.5rem; padding: 0; border: 0;
        }

        /* ── Forms (the inline send-test-message form) ─────────── */
        form.inline {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); padding: 1rem; margin-top: 0.5rem;
            box-shadow: var(--shadow-sm);
        }
        form.inline label {
            display: block; margin: 0.6rem 0 0.25rem;
            font-size: 0.78rem; color: var(--text-muted); font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.05em;
        }
        form.inline input[type=text] {
            width: 100%; max-width: 32rem; padding: 0.5rem 0.65rem;
            border: 1px solid var(--border-strong); border-radius: var(--radius-sm);
            font: inherit; background: var(--surface); color: var(--text);
        }
        form.inline input[type=text]:focus { outline: 2px solid var(--accent); outline-offset: -1px; border-color: var(--accent); }
        form.inline small {
            display: block; font-size: 0.78rem; color: var(--text-muted);
            margin: 0.3rem 0 0.5rem; line-height: 1.45;
        }
        .btn, form.inline button, form.edit-form button {
            display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem;
            padding: 0.45rem 0.9rem; border: 1px solid var(--accent);
            background: var(--accent); color: white;
            border-radius: var(--radius-sm); cursor: pointer;
            font-family: inherit; font-size: 0.875rem; line-height: 1.25;
            font-weight: 500; white-space: nowrap;
            transition: background 120ms, border-color 120ms, color 120ms;
        }
        .btn:hover, form.inline button:hover, form.edit-form button:hover { background: var(--accent-hover); border-color: var(--accent-hover); }
        .btn:disabled, .btn[disabled] { opacity: 0.55; cursor: not-allowed; }
        .btn.secondary {
            background: var(--surface); color: var(--accent);
            border-color: var(--border-strong);
        }
        .btn.secondary:hover {
            background: var(--surface-2); color: var(--accent-hover);
            border-color: var(--accent);
        }
        form.inline button { margin-top: 0.85rem; }
        .card-actions {
            display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.4rem;
        }

        /* ── Edit blocks (collapsible sections) ────────────────── */
        details.edit-block {
            margin: 0.75rem 0 0;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); overflow: hidden;
            box-shadow: var(--shadow-sm);
        }
        details.edit-block summary {
            cursor: pointer; padding: 0.6rem 0.85rem;
            font-size: 0.82rem; color: var(--text-muted); font-weight: 600;
            user-select: none;
            display: flex; align-items: center; gap: 0.4rem;
        }
        details.edit-block summary::before {
            content: "+"; font-size: 1rem; line-height: 1;
            color: var(--accent); width: 0.9rem; text-align: center;
            transition: transform 120ms;
        }
        details.edit-block[open] summary::before { content: "−"; }
        details.edit-block[open] summary {
            border-bottom: 1px solid var(--border);
            color: var(--text);
        }
        details.edit-block > *:not(summary) { padding: 0 0.85rem; }
        details.edit-block > p:first-of-type { padding-top: 0.85rem; }
        details.edit-block > form { padding-bottom: 0.85rem; }
        details.edit-block p.muted {
            font-size: 0.8rem; padding-bottom: 0.4rem; padding-top: 0.85rem;
        }
        form.edit-form {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 0.85rem 0.9rem; margin-top: 0.5rem;
            align-items: end;
        }
        form.edit-form > label {
            display: flex; flex-direction: column; gap: 0.3rem;
            font-size: 0.8rem; line-height: 1.35;
            color: var(--text-muted); font-weight: 500;
        }
        form.edit-form > label.checkbox-label {
            flex-direction: row; align-items: flex-start; gap: 0.5rem;
            font-weight: 400; color: var(--text); font-size: 0.85rem;
            padding: 0.45rem 0;
        }
        form.edit-form > label.checkbox-label input[type=checkbox] {
            margin: 0.15rem 0 0; flex-shrink: 0;
            width: 0.95rem; height: 0.95rem;
            accent-color: var(--accent);
        }
        form.edit-form > label > input[type=text],
        form.edit-form > label > input[type=password],
        form.edit-form > label > input[type=number],
        form.edit-form > label > select {
            width: 100%; margin: 0;
            padding: 0.45rem 0.6rem;
            border: 1px solid var(--border-strong); border-radius: var(--radius-sm);
            font-family: inherit; font-size: 0.875rem;
            background: var(--surface); color: var(--text);
            box-sizing: border-box;
        }
        form.edit-form > label > input[type=number] { max-width: 7rem; }
        form.edit-form input:focus, form.edit-form select:focus {
            outline: 2px solid var(--accent); outline-offset: -1px; border-color: var(--accent);
        }
        form.edit-form > button {
            grid-column: 1 / -1; justify-self: end; margin-top: 0.4rem;
        }

        /* ── Inline link buttons (the "remove" actions) ────────── */
        .link-btn {
            background: none; border: 0; color: var(--accent); cursor: pointer;
            padding: 0; font: inherit; font-size: 0.8rem;
        }
        .link-btn:hover { color: var(--accent-hover); text-decoration: underline; }

        /* ── Sign-out link in header ───────────────────────────── */
        a.signout { color: var(--text-muted); }

        /* ── Empty-state messaging ─────────────────────────────── */
        p.muted {
            background: var(--surface); border: 1px dashed var(--border-strong);
            padding: 1rem; border-radius: var(--radius); text-align: center;
            font-size: 0.875rem;
        }

        /* ── Responsive niceties ───────────────────────────────── */
        @@media (max-width: 720px) {
            .app-header { padding: 0.7rem 1rem; flex-wrap: wrap; }
            main { padding: 1rem; }
            .grid { grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); }
        }
    </style>
</head>
<body>
    @if (!TxGate.TxAllowed)
    {
        <div class="tx-stop-banner" role="alert">
            <span class="tx-stop-icon" aria-hidden="true"></span>
            <span>TX STOPPED</span>
            <span class="tx-stop-reason">@TxGate.BlockReason</span>
            <span class="spacer"></span>
            @if (!TxGate.LocalAllowed)
            {
                <form method="post" action="/TxControl/resume" class="tx-stop-form">
                    <button type="submit">Resume TX</button>
                </form>
            }
        </div>
    }
    else
    {
        <form method="post" action="/TxControl/stop" class="tx-stop-form tx-stop-floating">
            <button type="submit" class="tx-stop-btn" title="Stop all transmissions immediately">Stop TX</button>
        </form>
    }
    @RenderBody()
</body>
</html>
