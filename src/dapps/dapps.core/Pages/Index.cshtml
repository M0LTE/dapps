<p class="muted-inline">Plan B6.1 — connected-mode probe-and-map. Walks known peers (manual neighbours + AGW-bearer discovered peers) and confirms <code>DAPPSv1&gt;</code> is reachable. <span class="muted">Off by default; enable in <em>Edit configuration</em>. Auto-refreshes every 30s.</span></p>
<div class="probes-toolbar">
    <button type="button" onclick="dappsRunSweep()">Probe all now</button>
</div>
<table id="probes-table">
    <thead>
        <tr>
            <th>Callsign</th>
            <th>Source</th>
            <th>Last port</th>
            <th>Last probed</th>
            <th>Last success</th>
            <th class="numeric">Fails</th>
            <th class="numeric">Successes</th>
            <th>Last error</th>
            <th>Opt-out</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="probes-body">
        <tr><td colspan="10" class="muted" style="text-align:center;">No probes recorded yet.</td></tr>
    </tbody>
</table>

<script>
    (function () {
        const fmtAt = (iso) => iso ? new Date(iso).toISOString().replace('T', ' ').substring(0, 19) : '—';
        const fmtAgo = (iso) => {
            if (!iso) return '—';
            const s = Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 1000));
            if (s < 90) return `${s}s ago`;
            const m = Math.floor(s / 60);
            if (m < 90) return `${m}m ago`;
            const h = Math.floor(s / 3600);
            if (h < 36) return `${h}h ago`;
            return `${Math.floor(s / 86400)}d ago`;
        };
        const escape = (s) => String(s ?? '').replace(/[&<>"']/g, c =>
            ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
        async function poll() {
            try {
                const res = await fetch('/Probes', { credentials: 'same-origin' });
                if (!res.ok) return;
                const rows = await res.json();
                const body = document.getElementById('probes-body');
                if (!rows.length) {
                    body.innerHTML = '<tr><td colspan="10" class="muted" style="text-align:center;">No probes recorded yet.</td></tr>';
                    return;
                }
                body.innerHTML = rows.map(r => {
                    const reachable = r.lastSuccessAt && r.consecutiveFailures === 0;
                    const stale = r.lastProbedAt && !reachable;
                    const callPill = reachable
                        ? `<span class="pill ok">${escape(r.callsign)}</span>`
                        : (stale ? `<span class="pill warn">${escape(r.callsign)}</span>`
                                 : `<code>${escape(r.callsign)}</code>`);
                    // Source pill: "neighbour" / "discovered" plain;
                    // "via:CALLSIGN" gets an info pill so transitive
                    // candidates stand out in the table.
                    const src = r.source || 'neighbour';
                    const srcPill = src.startsWith('via:')
                        ? `<span class="pill info" title="learned from ${escape(src.substring(4))}'s peers list">${escape(src)}</span>`
                        : `<span class="muted">${escape(src)}</span>`;
                    const callQs = encodeURIComponent(r.callsign);
                    return `<tr>` +
                        `<td>${callPill}</td>` +
                        `<td>${srcPill}</td>` +
                        `<td class="numeric">${r.lastBpqPort ?? '—'}</td>` +
                        `<td class="muted">${fmtAgo(r.lastProbedAt)}</td>` +
                        `<td class="muted">${fmtAgo(r.lastSuccessAt)}</td>` +
                        `<td class="numeric">${r.consecutiveFailures}</td>` +
                        `<td class="numeric">${r.successCount}</td>` +
                        `<td class="muted">${escape(r.lastError || '—')}</td>` +
                        `<td><input type="checkbox" ${r.optOut ? 'checked' : ''} onchange="dappsSetOptOut('${callQs}', this.checked)" /></td>` +
                        `<td>` +
                        `<button type="button" onclick="dappsProbeOne('${callQs}')">Probe</button> ` +
                        `<button type="button" onclick="dappsForgetProbe('${callQs}')">Forget</button>` +
                        `</td>` +
                        `</tr>`;
                }).join('');
            } catch { /* try again next tick */ }
        }
        poll();
        setInterval(poll, 30000);
        // expose poll() for action handlers below
        window.dappsRefreshProbes = poll;
    })();
</script>

