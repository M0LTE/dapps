    <small class="muted">Where the message is going. Full callsign with SSID. Must be reachable through a configured neighbour or via routing.</small>

    <label for="send-payload">Payload</label>
    <input type="text" id="send-payload" name="Send.Payload" value="@Model.Send.Payload" placeholder="hello world" required />
    <small class="muted">Any UTF-8 text. DAPPS treats it as opaque bytes — apps decide what to do with it.</small>

    <button type="submit">Queue message</button>
</form>

<script>
    // Inline edit handlers for the configuration / neighbour / channel
    // forms. Each posts JSON to the existing controllers and reloads on
    // success — auth piggy-backs on the dapps.admin cookie the dashboard
    // is already loaded under.
    async function dappsPostJson(url, body, method) {
        const res = await fetch(url, {
            method: method || 'POST',
            headers: { 'content-type': 'application/json' },
            body: body == null ? null : JSON.stringify(body),
        });
        if (!res.ok && res.status !== 204) {
            const text = await res.text();
            alert(`Request failed (${res.status}): ${text}`);
            return false;
        }
        return true;
    }

    async function dappsSaveConfig(ev) {
        ev.preventDefault();
        const f = ev.target;
        const body = {
            Callsign: f.Callsign.value,
            NodeHost: f.NodeHost.value,
            AgwPort: parseInt(f.AgwPort.value, 10),
            DefaultBpqPort: parseInt(f.DefaultBpqPort.value, 10),
            MqttPort: parseInt(f.MqttPort.value, 10),
            UdpListenPort: parseInt(f.UdpListenPort.value, 10),
            AuthRequired: f.AuthRequired.checked,
            UpdateCheckEnabled: f.UpdateCheckEnabled.checked,
            ProbingEnabled: f.ProbingEnabled.checked,
            ProbeIntervalHours: parseInt(f.ProbeIntervalHours.value, 10),
            ProbeStrategy: f.ProbeStrategy.value,
            ProbeOvernightStartHour: parseInt(f.ProbeOvernightStartHour.value, 10),
            ProbeOvernightEndHour: parseInt(f.ProbeOvernightEndHour.value, 10),
            ProbeQuietWindowSeconds: parseInt(f.ProbeQuietWindowSeconds.value, 10),
            OpportunisticPollEnabled: f.OpportunisticPollEnabled.checked,
            ScheduledPollEnabled: f.ScheduledPollEnabled.checked,
            PollIntervalHours: parseInt(f.PollIntervalHours.value, 10),
            DiscoveryAirtimeBudgetSecondsPerHour: parseInt(f.DiscoveryAirtimeBudgetSecondsPerHour.value, 10),
        };
        if (await dappsPostJson('/Config', body)) location.reload();
    }

    async function dappsRotatePassword(ev) {
        ev.preventDefault();
        const pwd = ev.target.password.value;
        if (await dappsPostJson('/Config/admin-password', { password: pwd })) {
            ev.target.reset();
            alert('Password updated.');
        }
    }

    async function dappsAddNeighbour(ev) {
        ev.preventDefault();
        const f = ev.target;
        const body = {
            Callsign: f.callsign.value,
            BpqPort: f.bpqPort.value === '' ? null : parseInt(f.bpqPort.value, 10),
            UdpEndpoint: f.udpEndpoint.value || null,
        };
        if (await dappsPostJson('/Neighbours', body)) location.reload();
    }

    async function dappsDeleteNeighbour(callsign) {
        if (!confirm(`Remove neighbour ${callsign}?`)) return;
        if (await dappsPostJson('/Neighbours/' + encodeURIComponent(callsign), null, 'DELETE')) {
            location.reload();
        }
    }

    async function dappsAddChannel(ev) {
        ev.preventDefault();
        const f = ev.target;
        const body = {
            Bearer: f.bearer.value,
            ChannelKey: f.channelKey.value,
            LinkClass: f.linkClass.value,
            AirtimeBudgetSecondsPerHour: parseInt(f.airtimeBudgetSecondsPerHour.value, 10) || 0,
            SolicitIntervalSeconds: parseInt(f.solicitIntervalSeconds.value, 10) || 0,
        };
        if (await dappsPostJson('/DiscoveryChannels', body)) location.reload();
    }

    async function dappsDeleteChannel(id) {
        if (!confirm(`Remove discovery channel ${id}?`)) return;
        if (await dappsPostJson('/DiscoveryChannels/' + id, null, 'DELETE')) {
            location.reload();
        }
    }

    async function dappsSolicitChannel(id) {
        // B6.2 — fire-and-forget. Replies arrive on the regular beacon
        // path and populate "Discovered peers" automatically; no UI
        // refresh needed beyond the existing 30s poll.
        if (await dappsPostJson('/DiscoveryChannels/' + id + '/solicit', null)) {
            // Tiny user feedback so the operator knows the click landed.
            // No alert/reload — we don't want to disrupt their viewing.
        }
    }

    async function dappsRunSweep() {
        if (!confirm('Probe every known peer now? Uses other operators\' airtime.')) return;
        if (await dappsPostJson('/Probes/run', null)) {
            window.dappsRefreshProbes && window.dappsRefreshProbes();
        }
    }

    async function dappsProbeOne(callsign) {
        // /Probes/run/{callsign} returns the row JSON, but a simple
        // POST + refresh is fine for the dashboard — we don't need to
        // surface a per-probe banner.
        const url = '/Probes/run/' + callsign;
        const res = await fetch(url, { method: 'POST' });
        if (!res.ok && res.status !== 200 && res.status !== 204) {
            const text = await res.text();
            alert(`Probe failed (${res.status}): ${text}`);
            return;
        }
        window.dappsRefreshProbes && window.dappsRefreshProbes();
    }

    async function dappsSetOptOut(callsign, optOut) {
        await dappsPostJson('/Probes/' + callsign + '/optout', { OptOut: optOut });
        // No reload — the checkbox already shows the new state.
    }

    async function dappsForgetProbe(callsign) {
        if (!confirm(`Forget probe row for ${decodeURIComponent(callsign)}?`)) return;
        if (await dappsPostJson('/Probes/' + callsign, null, 'DELETE')) {
            window.dappsRefreshProbes && window.dappsRefreshProbes();
        }
    }

    async function dappsRunPollSweep() {
        if (!confirm('Poll every neighbour for queued mail now?')) return;
        if (await dappsPostJson('/Polls/run', null)) {
            window.dappsRefreshPolls && window.dappsRefreshPolls();
        }
    }

    async function dappsPollOne(callsign) {
        const url = '/Polls/run/' + callsign;
        const res = await fetch(url, { method: 'POST' });
        if (!res.ok && res.status !== 200 && res.status !== 204) {
            const text = await res.text();
            alert(`Poll failed (${res.status}): ${text}`);
            return;
        }
        window.dappsRefreshPolls && window.dappsRefreshPolls();
    }

    async function dappsSetPollOptOut(callsign, optOut) {
        await dappsPostJson('/Polls/' + callsign + '/optout', { OptOut: optOut });
    }

    async function dappsForgetPoll(callsign) {
        if (!confirm(`Forget poll row for ${decodeURIComponent(callsign)}?`)) return;
        if (await dappsPostJson('/Polls/' + callsign, null, 'DELETE')) {
            window.dappsRefreshPolls && window.dappsRefreshPolls();
        }
    }
</script>

</main>
