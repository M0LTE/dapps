@page
@model IndexModel
@{
    ViewData["Title"] = $"DAPPS — {Model.Options.Callsign}";
}

<header class="app-header">
    <span class="brand">
        <span class="dot"></span>
        DAPPS
        <span class="callsign">@Model.Options.Callsign</span>
    </span>
    <span class="spacer"></span>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a href="/Logout" class="signout">Sign out</a>
    }
</header>

<main>

@if (Model.FlashOk is not null)
{
    <div class="ok-banner">@Model.FlashOk</div>
}
@if (Model.FlashError is not null)
{
    <div class="err-banner">@Model.FlashError</div>
}

<h2>Node</h2>
<div class="grid">
    <div class="card">
        <div class="label">Callsign</div>
        <div class="value mono">@Model.Options.Callsign</div>
    </div>
    <div class="card">
        <div class="label">BPQ AGW</div>
        <div class="value mono">
            @Model.Options.NodeHost:@Model.Options.AgwPort
            <span class="dot @(Model.BpqAgwReachable ? "ok" : "warn")"></span>
        </div>
    </div>
    <div class="card">
        <div class="label">Default BPQ port</div>
        <div class="value mono">@Model.Options.DefaultBpqPort</div>
    </div>
    <div class="card">
        <div class="label">MQTT broker</div>
        <div class="value mono">:@Model.Options.MqttPort</div>
    </div>
    <div class="card">
        <div class="label">UDP listener</div>
        <div class="value mono">
            @(Model.Options.UdpListenPort > 0 ? $":{Model.Options.UdpListenPort}" : "—")
        </div>
    </div>
    <div class="card">
        <div class="label">App auth</div>
        <div class="value">
            @if (Model.Options.AuthRequired)
            {
                <span class="pill ok">required</span>
            }
            else
            {
                <span class="pill">open</span>
            }
        </div>
    </div>
</div>
<details class="edit-block">
    <summary>Edit configuration</summary>
    <p class="muted">Restart required for callsign, BPQ AGW host/port, MQTT port, UDP listener port to take effect.</p>
    <form class="edit-form" onsubmit="dappsSaveConfig(event)">
        <label>Callsign <input name="Callsign" value="@Model.Options.Callsign" required /></label>
        <label>Node host <input name="NodeHost" value="@Model.Options.NodeHost" required /></label>
        <label>AGW port <input name="AgwPort" type="number" min="1" max="65535" value="@Model.Options.AgwPort" required /></label>
        <label>Default BPQ port <input name="DefaultBpqPort" type="number" min="0" max="255" value="@Model.Options.DefaultBpqPort" required /></label>
        <label>MQTT port <input name="MqttPort" type="number" min="1" max="65535" value="@Model.Options.MqttPort" required /></label>
        <label>UDP listener port (0 = disabled) <input name="UdpListenPort" type="number" min="0" max="65535" value="@Model.Options.UdpListenPort" required /></label>
        <label class="checkbox-label"><input name="AuthRequired" type="checkbox" @(Model.Options.AuthRequired ? "checked" : "") /> App-interface auth required</label>
        <button type="submit">Save</button>
    </form>
</details>
<details class="edit-block">
    <summary>Rotate admin password</summary>
    <form class="edit-form" onsubmit="dappsRotatePassword(event)">
        <label>New password <input name="password" type="password" required minlength="8" /></label>
        <button type="submit">Set</button>
    </form>
    <p class="muted">Existing session stays valid until logout or 90-day expiry — only future logins use the new password.</p>
</details>

<h2>Queue</h2>
<div class="grid">
    <div class="card">
        <div class="label">Total messages</div>
        <div class="value">@Model.TotalMessages</div>
    </div>
    <div class="card">
        <div class="label">Pending outbound</div>
        <div class="value">@Model.PendingOutbound</div>
    </div>
    <div class="card">
        <div class="label">Undelivered local</div>
        <div class="value">@Model.UndeliveredLocal</div>
    </div>
    <div class="card">
        <div class="label">Neighbours</div>
        <div class="value">@Model.NeighbourCount</div>
    </div>
</div>

<h2>Neighbours</h2>
@if (Model.Neighbours.Count == 0)
{
    <p class="muted">No neighbours configured.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Callsign</th>
                <th>BPQ port</th>
                <th>UDP endpoint</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var n in Model.Neighbours)
        {
            <tr>
                <td>@n.Callsign</td>
                <td class="numeric">@(n.BpqPort?.ToString() ?? "—")</td>
                <td>@(n.UdpEndpoint ?? "—")</td>
                <td><button class="link-btn" onclick="dappsDeleteNeighbour('@n.Callsign')">remove</button></td>
            </tr>
        }
        </tbody>
    </table>
}
<details class="edit-block">
    <summary>Add neighbour</summary>
    <form class="edit-form" onsubmit="dappsAddNeighbour(event)">
        <label>Callsign <input name="callsign" required placeholder="GB7XYZ" /></label>
        <label>BPQ port <input name="bpqPort" type="number" min="0" max="255" placeholder="0" /></label>
        <label>UDP endpoint (optional) <input name="udpEndpoint" placeholder="host:port" /></label>
        <button type="submit">Add / update</button>
    </form>
</details>

<h2>Discovery channels</h2>
@if (Model.DiscoveryChannels.Count == 0)
{
    <p class="muted">No discovery channels configured.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Bearer</th>
                <th>Channel</th>
                <th>Link class</th>
                <th>Cost</th>
                <th>Beacon every</th>
                <th>Advertised TTL</th>
                <th>Enabled</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var c in Model.DiscoveryChannels)
        {
            <tr>
                <td>@c.Bearer</td>
                <td><code>@c.ChannelKey</code></td>
                <td>@c.LinkClass</td>
                <td class="numeric">@c.CostHint</td>
                <td class="numeric">@c.BeaconIntervalSeconds s</td>
                <td class="numeric">@c.AdvertisedTtlSeconds s</td>
                <td>@(c.Enabled ? "yes" : "no")</td>
                <td><button class="link-btn" onclick="dappsDeleteChannel(@c.Id)">remove</button></td>
            </tr>
        }
        </tbody>
    </table>
}
<details class="edit-block">
    <summary>Add discovery channel</summary>
    <form class="edit-form" onsubmit="dappsAddChannel(event)">
        <label>Bearer
            <select name="bearer">
                <option value="agw">agw</option>
                <option value="udp">udp</option>
            </select>
        </label>
        <label>Channel key <input name="channelKey" required placeholder="0 (BPQ port byte) or 239.0.0.1:54321" /></label>
        <label>Link class
            <select name="linkClass">
                <option>VhfUhfFm</option>
                <option>MeshCore</option>
                <option>Hf</option>
                <option>LanMulticast</option>
                <option>InternetIp</option>
            </select>
        </label>
        <button type="submit">Add / update</button>
    </form>
</details>

<h2>Discovered peers</h2>
@if (Model.DiscoveredPeers.Count == 0)
{
    <p class="muted">No peers heard yet.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Callsign</th>
                <th>Bearer</th>
                <th>Channel</th>
                <th>Link class</th>
                <th>Cost</th>
                <th>Hops</th>
                <th>Source</th>
                <th>Last seen</th>
                <th>TTL</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model.DiscoveredPeers)
        {
            <tr>
                <td>@p.Callsign</td>
                <td>@p.Bearer</td>
                <td><code>@p.ChannelKey</code></td>
                <td>@p.LinkClass</td>
                <td class="numeric">@p.CostHint</td>
                <td class="numeric">@p.Hops</td>
                <td>@(p.UdpEndpoint ?? (p.BpqPort is { } bp ? $"BPQ port {bp}" : "—"))</td>
                <td>@IndexModel.Age(p.LastSeen) ago</td>
                <td class="numeric">@p.TtlSeconds s</td>
            </tr>
        }
        </tbody>
    </table>
}

<h2>Live inbound <span id="sse-status" class="pill">connecting</span></h2>
<p class="muted">
    Server-Sent Events feed of messages arriving at this node. Clears
    on page reload — for persistent history see "Recent messages" below.
</p>
<table id="sse-table">
    <thead>
        <tr>
            <th>Time (UTC)</th>
            <th>Id</th>
            <th>Source</th>
            <th>Destination</th>
            <th>Bytes</th>
            <th>TTL</th>
        </tr>
    </thead>
    <tbody id="sse-body">
        <tr id="sse-empty"><td colspan="6" class="muted">Waiting for inbound traffic…</td></tr>
    </tbody>
</table>

<script>
    (function () {
        const status = document.getElementById('sse-status');
        const body = document.getElementById('sse-body');
        const empty = document.getElementById('sse-empty');
        const es = new EventSource('/Events/inbound');
        es.onopen = () => {
            status.textContent = 'live';
            status.className = 'pill ok';
            status.innerHTML = '<span class="dot live"></span> live';
        };
        es.onerror = () => {
            status.textContent = 'reconnecting';
            status.className = 'pill warn';
        };
        es.addEventListener('inbound', (e) => {
            const ev = JSON.parse(e.data);
            if (empty) empty.remove();
            const row = document.createElement('tr');
            const ts = new Date(ev.receivedAt).toISOString().substring(11, 19);
            row.innerHTML =
                `<td><code>${ts}</code></td>` +
                `<td><code>${ev.id}</code></td>` +
                `<td>${ev.sourceCallsign}</td>` +
                `<td>${ev.destination}</td>` +
                `<td class="numeric">${ev.payloadLength}</td>` +
                `<td class="numeric">${ev.ttl ?? '—'}</td>`;
            body.insertBefore(row, body.firstChild);
            // Keep at most 50 rows so the page doesn't grow unbounded.
            while (body.children.length > 50) body.removeChild(body.lastChild);
        });
    })();
</script>

<h2>Recent messages</h2>
@if (Model.RecentMessages.Count == 0)
{
    <p class="muted">No messages yet.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Destination</th>
                <th>Source</th>
                <th>Bytes</th>
                <th>Status</th>
                <th>TTL</th>
                <th>Age</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var m in Model.RecentMessages)
        {
            var status = IndexModel.MessageStatus(m, Model.Options.Callsign);
            <tr>
                <td><code>@m.Id</code></td>
                <td>@m.Destination</td>
                <td>@m.SourceCallsign</td>
                <td class="numeric">@m.Payload.Length</td>
                <td><span class="pill @status.PillClass">@status.Label</span></td>
                <td class="numeric">@(m.Ttl?.ToString() ?? "—")</td>
                <td class="muted">@IndexModel.Age(m.CreatedAt)</td>
            </tr>
        }
        </tbody>
    </table>
}

<h2>Send a test message</h2>
<p class="muted">
    Posts an outbound message via <code>Database.SubmitOutboundMessage</code>, just
    like an app would over MQTT or REST. Useful for verifying a node-to-node link.
</p>
<form class="inline" method="post" asp-page-handler="Send">
    <label for="send-app">App</label>
    <input type="text" id="send-app" name="Send.App" value="@Model.Send.App" placeholder="myapp" required />

    <label for="send-dest">Destination callsign</label>
    <input type="text" id="send-dest" name="Send.Destination" value="@Model.Send.Destination" placeholder="G7XYZ-9" required />

    <label for="send-payload">Payload (UTF-8 text)</label>
    <input type="text" id="send-payload" name="Send.Payload" value="@Model.Send.Payload" placeholder="hello world" required />

    <button type="submit">Queue message</button>
</form>

<script>
    // Inline edit handlers for the configuration / neighbour / channel
    // forms. Each posts JSON to the existing controllers and reloads on
    // success — auth piggy-backs on the dapps.admin cookie the dashboard
    // is already loaded under.
    async function dappsPostJson(url, body, method) {
        const res = await fetch(url, {
            method: method || 'POST',
            headers: { 'content-type': 'application/json' },
            body: body == null ? null : JSON.stringify(body),
        });
        if (!res.ok && res.status !== 204) {
            const text = await res.text();
            alert(`Request failed (${res.status}): ${text}`);
            return false;
        }
        return true;
    }

    async function dappsSaveConfig(ev) {
        ev.preventDefault();
        const f = ev.target;
        const body = {
            Callsign: f.Callsign.value,
            NodeHost: f.NodeHost.value,
            AgwPort: parseInt(f.AgwPort.value, 10),
            DefaultBpqPort: parseInt(f.DefaultBpqPort.value, 10),
            MqttPort: parseInt(f.MqttPort.value, 10),
            UdpListenPort: parseInt(f.UdpListenPort.value, 10),
            AuthRequired: f.AuthRequired.checked,
        };
        if (await dappsPostJson('/Config', body)) location.reload();
    }

    async function dappsRotatePassword(ev) {
        ev.preventDefault();
        const pwd = ev.target.password.value;
        if (await dappsPostJson('/Config/admin-password', { password: pwd })) {
            ev.target.reset();
            alert('Password updated.');
        }
    }

    async function dappsAddNeighbour(ev) {
        ev.preventDefault();
        const f = ev.target;
        const body = {
            Callsign: f.callsign.value,
            BpqPort: f.bpqPort.value === '' ? null : parseInt(f.bpqPort.value, 10),
            UdpEndpoint: f.udpEndpoint.value || null,
        };
        if (await dappsPostJson('/Neighbours', body)) location.reload();
    }

    async function dappsDeleteNeighbour(callsign) {
        if (!confirm(`Remove neighbour ${callsign}?`)) return;
        if (await dappsPostJson('/Neighbours/' + encodeURIComponent(callsign), null, 'DELETE')) {
            location.reload();
        }
    }

    async function dappsAddChannel(ev) {
        ev.preventDefault();
        const f = ev.target;
        const body = {
            Bearer: f.bearer.value,
            ChannelKey: f.channelKey.value,
            LinkClass: f.linkClass.value,
        };
        if (await dappsPostJson('/DiscoveryChannels', body)) location.reload();
    }

    async function dappsDeleteChannel(id) {
        if (!confirm(`Remove discovery channel ${id}?`)) return;
        if (await dappsPostJson('/DiscoveryChannels/' + id, null, 'DELETE')) {
            location.reload();
        }
    }
</script>

</main>
