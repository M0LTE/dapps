@inject SystemOptionsBackedTxGate TxGate
@inject Microsoft.Extensions.Options.IOptionsMonitor<SystemOptions> SysOpts
@{
    var title = ViewData["Title"] as string ?? "DAPPS";
    var active = ViewData["Active"] as string ?? "";
    var pageTitle = ViewData["PageTitle"] as string;
    var pageSubtitle = ViewData["PageSubtitle"] as string;
    var hasShell = !((ViewData["NoShell"] as bool?) ?? false);
    var refreshSeconds = ViewData["RefreshSeconds"] as int?;
    var callsignRaw = SysOpts.CurrentValue.Callsign;
    var callsign = string.IsNullOrWhiteSpace(callsignRaw) ? "N0CALL" : callsignRaw;
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    @if (refreshSeconds is > 0)
    {
        <meta http-equiv="refresh" content="@refreshSeconds" />
    }
    <title>@title</title>
    <style>
        :root {
            /* Dark "operator console" palette - cool blue/slate with a
               scope-green signal accent. Tuned to keep mono callsigns
               legible against the surface. */
            --bg-0: #07090f;
            --bg-1: #0b0f1a;
            --bg-2: #0f1524;
            --surface: #121a2c;
            --surface-2: #182238;
            --surface-3: #1f2b46;
            --border: #1c2740;
            --border-strong: #2a3a5e;
            --border-soft: #15203a;

            --text: #e6ecf6;
            --text-muted: #8a9bbd;
            --text-dim: #5d6f93;

            --accent: #4cc9f0;
            --accent-hover: #7dd3f1;
            --accent-soft: rgba(76, 201, 240, 0.12);

            --signal: #4ade80;
            --signal-soft: rgba(74, 222, 128, 0.14);
            --signal-glow: rgba(74, 222, 128, 0.45);

            --warn: #fbbf24;
            --warn-soft: rgba(251, 191, 36, 0.14);

            --err: #f87171;
            --err-soft: rgba(248, 113, 113, 0.16);
            --err-strong: #ef4444;

            --info: #818cf8;
            --info-soft: rgba(129, 140, 248, 0.14);

            --shadow-sm: 0 1px 2px rgba(0,0,0,0.4);
            --shadow:    0 8px 24px rgba(0,0,0,0.45), 0 2px 6px rgba(0,0,0,0.3);
            --shadow-lg: 0 24px 48px rgba(0,0,0,0.55), 0 6px 12px rgba(0,0,0,0.35);

            --radius-sm: 6px;
            --radius:    10px;
            --radius-lg: 14px;

            --font-ui: "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI Variable", "Segoe UI", Roboto, sans-serif;
            --font-mono: ui-monospace, "JetBrains Mono", "SF Mono", "Cascadia Mono", Menlo, Consolas, monospace;
            --font-display: "Inter", var(--font-ui);

            --topbar-h: 56px;
            --sidebar-w: 224px;
            --sidebar-w-collapsed: 64px;
        }

        html[data-theme="light"] {
            --bg-0: #f4f6fb;
            --bg-1: #eef2f8;
            --bg-2: #ffffff;
            --surface: #ffffff;
            --surface-2: #f3f6fb;
            --surface-3: #e7eef7;
            --border: #dde4ee;
            --border-strong: #c2cdde;
            --border-soft: #ebf0f7;

            --text: #0f1729;
            --text-muted: #56678a;
            --text-dim: #8294b3;

            --accent: #0284c7;
            --accent-hover: #0369a1;
            --accent-soft: rgba(2, 132, 199, 0.10);

            --signal: #16a34a;
            --signal-soft: rgba(22, 163, 74, 0.10);
            --signal-glow: rgba(22, 163, 74, 0.35);

            --warn: #b45309;
            --warn-soft: rgba(180, 83, 9, 0.10);

            --err: #dc2626;
            --err-soft: rgba(220, 38, 38, 0.10);
            --err-strong: #dc2626;

            --info: #4f46e5;
            --info-soft: rgba(79, 70, 229, 0.10);

            --shadow-sm: 0 1px 2px rgba(15,23,42,0.04);
            --shadow:    0 4px 12px rgba(15,23,42,0.06), 0 1px 2px rgba(15,23,42,0.04);
            --shadow-lg: 0 12px 32px rgba(15,23,42,0.10);
        }

        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body {
            font-family: var(--font-ui);
            background:
                radial-gradient(1200px 600px at 12% -8%, rgba(76,201,240,0.07), transparent 60%),
                radial-gradient(900px 500px at 100% 0%, rgba(129,140,248,0.06), transparent 60%),
                var(--bg-0);
            color: var(--text);
            line-height: 1.5;
            font-size: 14px;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
        }

        /* ========================================================
           Top bar - sticky, full width, status at a glance
           ======================================================== */
        .topbar {
            position: sticky; top: 0; z-index: 30;
            height: var(--topbar-h);
            display: flex; align-items: center;
            padding: 0 1rem;
            background: color-mix(in srgb, var(--bg-1) 88%, transparent);
            backdrop-filter: saturate(180%) blur(10px);
            border-bottom: 1px solid var(--border);
            gap: 1rem;
        }
        .topbar .brand {
            display: inline-flex; align-items: center; gap: 0.55rem;
            font-weight: 600; font-size: 1rem;
            letter-spacing: 0.02em;
            color: var(--text);
            text-decoration: none;
        }
        .brand-mark {
            position: relative;
            width: 22px; height: 22px;
            border-radius: 5px;
            background:
                radial-gradient(circle at 30% 30%, var(--signal), transparent 50%),
                linear-gradient(135deg, var(--surface-3), var(--surface));
            border: 1px solid var(--border-strong);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
        }
        .brand-mark::after {
            /* Faint scan-line through the brand mark */
            content: "";
            position: absolute; inset: 0;
            background: repeating-linear-gradient(0deg,
                rgba(255,255,255,0.06) 0px, rgba(255,255,255,0.06) 1px,
                transparent 1px, transparent 3px);
            border-radius: inherit;
            opacity: 0.5;
        }
        .brand-name { letter-spacing: 0.05em; }

        .callsign-chip {
            font-family: var(--font-mono);
            font-weight: 600; font-size: 0.82rem;
            padding: 0.18rem 0.55rem;
            border: 1px solid var(--border-strong);
            border-radius: 5px;
            background: var(--surface);
            color: var(--accent);
            letter-spacing: 0.04em;
            white-space: nowrap;
        }

        .topbar-status {
            display: flex; align-items: center; gap: 0.6rem;
            margin-left: 0.5rem;
            flex-wrap: wrap;
        }
        .status-chip {
            display: inline-flex; align-items: center; gap: 0.4rem;
            padding: 0.3rem 0.6rem;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 999px;
            font-size: 0.75rem;
            color: var(--text-muted);
            white-space: nowrap;
        }
        .status-chip .lbl {
            text-transform: uppercase; letter-spacing: 0.06em;
            font-weight: 600; font-size: 0.66rem;
        }
        .status-chip code, .status-chip .v {
            font-family: var(--font-mono);
            color: var(--text);
            font-size: 0.78rem;
        }

        .led {
            width: 9px; height: 9px; border-radius: 50%;
            background: var(--text-dim);
            box-shadow: 0 0 0 0 transparent;
            flex-shrink: 0;
            display: inline-block;
        }
        .led.on    { background: var(--signal); box-shadow: 0 0 8px var(--signal-glow); }
        .led.warn  { background: var(--warn);   box-shadow: 0 0 8px rgba(251,191,36,0.45); }
        .led.err   { background: var(--err);    box-shadow: 0 0 8px rgba(248,113,113,0.5); }
        .led.live  { background: var(--signal); box-shadow: 0 0 8px var(--signal-glow);
                     animation: ledpulse 1.8s ease-in-out infinite; }
        @@keyframes ledpulse {
            0%, 100% { box-shadow: 0 0 8px var(--signal-glow); }
            50%      { box-shadow: 0 0 0 5px transparent; }
        }

        .topbar-spacer { flex: 1 1 auto; }

        .topbar-actions { display: flex; align-items: center; gap: 0.5rem; }
        .topbar-actions a, .topbar-actions button {
            font: inherit; font-size: 0.82rem;
            color: var(--text-muted);
            text-decoration: none;
            background: transparent;
            border: 1px solid transparent;
            border-radius: 6px;
            padding: 0.35rem 0.6rem;
            cursor: pointer;
        }
        .topbar-actions a:hover, .topbar-actions button:hover {
            color: var(--text); background: var(--surface);
            border-color: var(--border);
        }

        /* ========================================================
           TX kill-switch banners (above the topbar when triggered)
           ======================================================== */
        .tx-banner-stop, .tx-banner-good {
            display: flex; align-items: center; gap: 0.85rem;
            padding: 0.55rem 1rem;
            position: sticky; top: 0; z-index: 40;
        }
        .tx-banner-stop {
            background: linear-gradient(180deg, var(--err-strong), color-mix(in srgb, var(--err-strong) 80%, black));
            color: white;
            box-shadow: 0 2px 12px rgba(220, 38, 38, 0.4);
            animation: txstoppulse 2s ease-in-out infinite;
        }
        @@keyframes txstoppulse {
            0%, 100% { box-shadow: 0 2px 12px rgba(220, 38, 38, 0.4); }
            50%      { box-shadow: 0 2px 18px rgba(220, 38, 38, 0.7); }
        }
        .tx-banner-stop .icon {
            width: 16px; height: 16px; border-radius: 3px;
            background: white; flex-shrink: 0;
        }
        .tx-banner-stop .label { font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; font-size: 0.85rem; }
        .tx-banner-stop .reason { opacity: 0.92; font-size: 0.85rem; }
        .tx-banner-stop button {
            margin-left: auto;
            background: white; color: var(--err-strong);
            border: 0; border-radius: 5px;
            padding: 0.35rem 0.85rem;
            font: inherit; font-weight: 600; font-size: 0.8rem;
            cursor: pointer;
        }
        .tx-stop-inline-form { margin: 0; }

        /* The "Stop TX" button is a permanent affordance on the topbar
           when transmissions are live; one-click safety control. */
        .tx-killbtn {
            display: inline-flex; align-items: center; gap: 0.4rem;
            background: var(--err-soft); color: var(--err);
            border: 1px solid color-mix(in srgb, var(--err) 30%, var(--border));
            border-radius: 6px;
            padding: 0.35rem 0.7rem;
            font: inherit; font-weight: 600; font-size: 0.75rem;
            text-transform: uppercase; letter-spacing: 0.06em;
            cursor: pointer;
        }
        .tx-killbtn:hover { background: var(--err-strong); color: white; border-color: var(--err-strong); }
        .tx-killbtn .led { background: var(--err); box-shadow: 0 0 6px rgba(248,113,113,0.5); }

        /* ========================================================
           Application shell: sidebar + content
           ======================================================== */
        .shell { display: flex; min-height: calc(100vh - var(--topbar-h)); }
        .sidebar {
            width: var(--sidebar-w);
            flex-shrink: 0;
            border-right: 1px solid var(--border);
            background: linear-gradient(180deg, var(--bg-1), var(--bg-0));
            padding: 1rem 0.75rem 1.25rem;
            position: sticky;
            top: var(--topbar-h);
            align-self: flex-start;
            height: calc(100vh - var(--topbar-h));
            overflow-y: auto;
        }
        .nav-group { display: flex; flex-direction: column; gap: 2px; }
        .nav-section {
            padding: 0.75rem 0.6rem 0.4rem;
            font-size: 0.65rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.1em;
            color: var(--text-dim);
        }
        .nav-link {
            display: flex; align-items: center; gap: 0.6rem;
            padding: 0.45rem 0.65rem;
            border-radius: 7px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.88rem;
            border: 1px solid transparent;
            white-space: nowrap;
        }
        .nav-link:hover { color: var(--text); background: var(--surface); }
        .nav-link.active {
            color: var(--text); background: var(--accent-soft);
            border-color: color-mix(in srgb, var(--accent) 30%, var(--border));
            box-shadow: inset 2px 0 0 var(--accent);
        }
        .nav-link .ic {
            width: 18px; height: 18px; flex-shrink: 0;
            color: currentColor;
        }
        .nav-link .badge {
            margin-left: auto;
            font-family: var(--font-mono); font-size: 0.7rem;
            padding: 0.05rem 0.4rem;
            border-radius: 4px;
            background: var(--surface-2); color: var(--text-muted);
        }
        .nav-link.active .badge { background: var(--surface-3); color: var(--text); }

        main {
            flex: 1 1 auto;
            min-width: 0;
            padding: 1.25rem 1.5rem 3rem;
            max-width: 1400px;
        }

        /* ========================================================
           Page header (sits inside main)
           ======================================================== */
        .page-head {
            display: flex; align-items: flex-start; gap: 1rem;
            margin: 0 0 1.25rem;
        }
        .page-head h1 {
            margin: 0; font-size: 1.4rem; font-weight: 600;
            letter-spacing: -0.01em;
            color: var(--text);
        }
        .page-head .subtitle {
            color: var(--text-muted); font-size: 0.9rem;
            margin-top: 0.25rem; max-width: 70ch;
        }
        .page-head .actions { margin-left: auto; display: flex; gap: 0.5rem; flex-wrap: wrap; }

        /* Tab strip directly below the page header */
        .tabs {
            display: flex; gap: 2px; flex-wrap: wrap;
            border-bottom: 1px solid var(--border);
            margin: 0 0 1.25rem;
        }
        .tabs a {
            padding: 0.55rem 0.85rem;
            color: var(--text-muted); text-decoration: none;
            border-bottom: 2px solid transparent;
            font-size: 0.88rem;
            margin-bottom: -1px;
        }
        .tabs a:hover { color: var(--text); }
        .tabs a.active {
            color: var(--text);
            border-bottom-color: var(--accent);
            font-weight: 600;
        }
        .tabs a .count {
            display: inline-block;
            margin-left: 0.4rem;
            font-family: var(--font-mono);
            font-size: 0.72rem;
            color: var(--text-dim);
            padding: 0.05rem 0.35rem;
            border-radius: 4px;
            background: var(--surface);
            border: 1px solid var(--border);
        }

        /* ========================================================
           Cards + grid
           ======================================================== */
        .grid { display: grid; gap: 0.85rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
        .grid-2 { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); }
        .grid-3 { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.1rem;
            box-shadow: var(--shadow-sm);
            position: relative;
        }
        .card .label {
            font-size: 0.68rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.08em;
            color: var(--text-dim);
        }
        .card .value {
            margin-top: 0.45rem;
            font-size: 1.5rem; font-weight: 600;
            font-variant-numeric: tabular-nums;
            letter-spacing: -0.01em;
            display: flex; align-items: center; gap: 0.5rem;
            min-width: 0;
        }
        .card .value.mono { font-family: var(--font-mono); font-size: 1.05rem; font-weight: 500; }
        .card .caption { margin-top: 0.4rem; font-size: 0.78rem; color: var(--text-muted); line-height: 1.45; }
        .card-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.6rem; }

        /* Status tile - large LED + label, used on Overview hero row */
        .tile {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.1rem;
            display: flex; flex-direction: column; gap: 0.4rem;
            min-height: 96px;
            position: relative; overflow: hidden;
        }
        .tile::before {
            content: ""; position: absolute; inset: 0; pointer-events: none;
            background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 40%);
            opacity: 0; transition: opacity 200ms;
        }
        .tile.is-on::before { opacity: 0.8; background: linear-gradient(180deg, var(--signal-soft), transparent 40%); }
        .tile.is-warn::before { opacity: 0.8; background: linear-gradient(180deg, var(--warn-soft), transparent 40%); }
        .tile.is-err::before { opacity: 0.9; background: linear-gradient(180deg, var(--err-soft), transparent 40%); }
        .tile .head { display: flex; align-items: center; gap: 0.5rem; }
        .tile .head .led { width: 10px; height: 10px; }
        .tile .head .lbl {
            font-size: 0.7rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.08em;
            color: var(--text-dim);
        }
        .tile .head .pill { margin-left: auto; }
        .tile .v {
            font-family: var(--font-mono); font-size: 1.05rem;
            font-weight: 500; letter-spacing: -0.01em;
            color: var(--text);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .tile .sub { font-size: 0.78rem; color: var(--text-muted); line-height: 1.4; }

        /* ========================================================
           Tables
           ======================================================== */
        table {
            width: 100%; border-collapse: separate; border-spacing: 0;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            font-size: 0.875rem;
            box-shadow: var(--shadow-sm);
        }
        thead th {
            background: var(--bg-1);
            color: var(--text-dim);
            font-size: 0.68rem; text-transform: uppercase;
            letter-spacing: 0.07em; font-weight: 700;
            text-align: left;
            padding: 0.55rem 0.85rem;
            border-bottom: 1px solid var(--border);
        }
        tbody td {
            padding: 0.55rem 0.85rem;
            border-bottom: 1px solid var(--border-soft);
            vertical-align: middle;
        }
        tbody tr:last-child td { border-bottom: none; }
        tbody tr:hover { background: color-mix(in srgb, var(--surface-2) 60%, transparent); }
        td.numeric, th.numeric { text-align: right; font-variant-numeric: tabular-nums; }
        tr.warn td { background: var(--warn-soft); }
        td .actions { display: inline-flex; gap: 0.5rem; }

        /* ========================================================
           Pills + dots
           ======================================================== */
        .pill {
            display: inline-flex; align-items: center; gap: 0.3rem;
            padding: 0.12rem 0.5rem;
            border-radius: 999px;
            font-size: 0.7rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.04em;
            background: var(--surface-2); color: var(--text-muted);
            border: 1px solid var(--border);
            white-space: nowrap;
        }
        .pill.ok    { background: var(--signal-soft); color: var(--signal); border-color: color-mix(in srgb, var(--signal) 25%, var(--border)); }
        .pill.warn  { background: var(--warn-soft);   color: var(--warn);   border-color: color-mix(in srgb, var(--warn) 25%, var(--border)); }
        .pill.err   { background: var(--err-soft);    color: var(--err);    border-color: color-mix(in srgb, var(--err) 25%, var(--border)); }
        .pill.info  { background: var(--info-soft);   color: var(--info);   border-color: color-mix(in srgb, var(--info) 25%, var(--border)); }
        .pill.accent{ background: var(--accent-soft); color: var(--accent); border-color: color-mix(in srgb, var(--accent) 25%, var(--border)); }
        .dot { width: 8px; height: 8px; display: inline-block; border-radius: 50%; }

        /* ========================================================
           Banners
           ======================================================== */
        .ok-banner, .err-banner, .info-banner {
            padding: 0.65rem 0.9rem; border-radius: var(--radius);
            margin: 0 0 1rem;
            font-size: 0.875rem;
            border: 1px solid transparent;
        }
        .ok-banner   { background: var(--signal-soft); border-color: color-mix(in srgb, var(--signal) 25%, transparent); color: var(--signal); }
        .err-banner  { background: var(--err-soft);    border-color: color-mix(in srgb, var(--err) 25%, transparent);    color: var(--err); }
        .info-banner { background: var(--info-soft);   border-color: color-mix(in srgb, var(--info) 25%, transparent);   color: var(--info); }

        /* ========================================================
           Forms
           ======================================================== */
        label { color: var(--text-muted); font-size: 0.78rem; font-weight: 600; }
        input[type=text], input[type=password], input[type=number], textarea, select {
            background: var(--bg-2); color: var(--text);
            border: 1px solid var(--border-strong);
            border-radius: var(--radius-sm);
            padding: 0.5rem 0.65rem;
            font: inherit; font-size: 0.88rem;
            width: 100%;
        }
        input:focus, textarea:focus, select:focus {
            outline: 2px solid var(--accent); outline-offset: -1px;
            border-color: var(--accent);
        }
        textarea { resize: vertical; min-height: 4rem; font-family: var(--font-mono); }

        .field-grid {
            display: grid;
            gap: 0.85rem 0.95rem;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }
        .field {
            display: flex; flex-direction: column; gap: 0.3rem;
        }
        .field label { color: var(--text-muted); font-size: 0.78rem; font-weight: 600; }
        .field .hint { font-size: 0.75rem; color: var(--text-dim); margin-top: 0.15rem; line-height: 1.4; }
        .field-checkbox {
            display: flex; align-items: flex-start; gap: 0.55rem;
            font-size: 0.86rem; color: var(--text);
            line-height: 1.4;
        }
        .field-checkbox input[type=checkbox] {
            width: 16px; height: 16px;
            margin: 2px 0 0; accent-color: var(--accent); flex-shrink: 0;
        }
        .field-checkbox .hint { color: var(--text-muted); }

        .btn, button.btn {
            display: inline-flex; align-items: center; justify-content: center;
            gap: 0.4rem;
            padding: 0.5rem 0.95rem;
            border: 1px solid var(--accent);
            background: var(--accent);
            color: white;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font: inherit; font-size: 0.875rem; font-weight: 500;
            line-height: 1.2;
            text-decoration: none;
            white-space: nowrap;
            transition: background 120ms, border-color 120ms, color 120ms;
        }
        html[data-theme="dark"] .btn { color: #06121e; }
        .btn:hover { background: var(--accent-hover); border-color: var(--accent-hover); }
        .btn:disabled, .btn[disabled] { opacity: 0.55; cursor: not-allowed; }
        .btn.secondary {
            background: transparent; color: var(--accent);
            border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--border));
        }
        .btn.secondary:hover { background: var(--accent-soft); color: var(--accent-hover); border-color: var(--accent); }
        .btn.ghost {
            background: transparent; color: var(--text);
            border: 1px solid var(--border-strong);
        }
        .btn.ghost:hover { background: var(--surface); border-color: var(--border-strong); }
        .btn.danger {
            background: var(--err-strong); border-color: var(--err-strong); color: white;
        }
        .btn.danger:hover { background: color-mix(in srgb, var(--err-strong) 80%, black); }
        .btn.sm { padding: 0.32rem 0.7rem; font-size: 0.8rem; }

        .link-btn {
            background: none; border: 0; padding: 0;
            color: var(--accent); cursor: pointer;
            font: inherit; font-size: 0.82rem;
        }
        .link-btn:hover { color: var(--accent-hover); text-decoration: underline; }
        .link-btn.danger { color: var(--err); }
        .link-btn.danger:hover { color: var(--err-strong); }

        /* ========================================================
           Misc utilities
           ======================================================== */
        h2 {
            font-size: 0.78rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.1em;
            color: var(--text-muted);
            margin: 1.6rem 0 0.7rem;
        }
        h2:first-of-type { margin-top: 0; }
        h2 .pill { font-size: 0.65rem; vertical-align: middle; margin-left: 0.4rem; }
        h3.subhead {
            font-size: 0.74rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.08em;
            color: var(--text-muted);
            margin: 1.2rem 0 0.55rem;
        }
        .muted { color: var(--text-muted); }
        .muted-inline { color: var(--text-muted); font-size: 0.85rem; margin: 0.25rem 0 0.6rem; line-height: 1.5; }
        .empty {
            padding: 1rem;
            border: 1px dashed var(--border-strong);
            border-radius: var(--radius);
            text-align: center;
            color: var(--text-muted);
            font-size: 0.875rem;
            background: color-mix(in srgb, var(--surface) 50%, transparent);
        }
        code {
            font-family: var(--font-mono); font-size: 0.84em;
            background: var(--surface-2); color: var(--text);
            padding: 0.05rem 0.35rem; border-radius: 4px;
            border: 1px solid var(--border);
        }
        td code { background: transparent; padding: 0; border: 0; color: var(--accent); }

        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.1rem;
            box-shadow: var(--shadow-sm);
        }
        .panel + .panel { margin-top: 1rem; }
        .panel h3 { margin: 0 0 0.5rem; font-size: 1rem; font-weight: 600; }
        .panel .panel-sub { font-size: 0.85rem; color: var(--text-muted); margin: 0 0 1rem; line-height: 1.45; }

        .row-form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.6rem 0.7rem;
            align-items: end;
        }
        .row-form button { grid-column: -2 / -1; justify-self: end; }

        /* Activity ticker (used on Overview) */
        .ticker {
            background: var(--bg-2);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 0.5rem 0.75rem;
            max-height: 16rem;
            overflow-y: auto;
            font-family: var(--font-mono);
            font-size: 0.78rem;
        }
        .ticker .row {
            display: grid; grid-template-columns: 6.5rem 7rem 1fr;
            gap: 0.5rem;
            padding: 0.18rem 0;
            border-bottom: 1px solid var(--border-soft);
            color: var(--text-muted);
            white-space: nowrap;
        }
        .ticker .row:last-child { border-bottom: 0; }
        .ticker .row .t { color: var(--text-dim); }
        .ticker .row .k { color: var(--accent); }
        .ticker .row .k.ok { color: var(--signal); }
        .ticker .row .k.warn { color: var(--warn); }
        .ticker .row .k.err { color: var(--err); }
        .ticker .row .m { color: var(--text); overflow: hidden; text-overflow: ellipsis; }

        /* Activity sparkline (svg, on Overview) */
        .sparkbox {
            background: linear-gradient(180deg, var(--surface), var(--bg-2));
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 0.85rem 1rem 0.5rem;
        }
        .spark-svg { width: 100%; height: 60px; display: block; }
        .spark-meta {
            display: flex; gap: 1rem; font-size: 0.8rem; color: var(--text-muted);
            justify-content: space-between; flex-wrap: wrap; margin-top: 0.4rem;
        }

        /* Airtime bar */
        .gauge { display: flex; align-items: center; gap: 0.5rem; min-width: 7rem; }
        .gauge .bar {
            position: relative;
            flex: 1 1 auto;
            height: 6px;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 999px;
            overflow: hidden;
        }
        .gauge .fill {
            position: absolute; inset: 0;
            background: linear-gradient(90deg, var(--signal), var(--accent));
            transform-origin: left;
            transform: scaleX(0);
            transition: transform 280ms ease, background 280ms;
        }
        .gauge.warn .fill { background: linear-gradient(90deg, var(--warn), var(--err)); }
        .gauge.err  .fill { background: var(--err); }

        /* Toggle switch (theme) */
        .theme-toggle {
            display: inline-flex; align-items: center; gap: 0.4rem;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 999px; padding: 0.18rem 0.4rem 0.18rem 0.55rem;
            cursor: pointer; font-size: 0.75rem; color: var(--text-muted);
        }
        .theme-toggle:hover { color: var(--text); }
        .theme-toggle .knob {
            width: 10px; height: 10px; border-radius: 50%;
            background: var(--signal); box-shadow: 0 0 6px var(--signal-glow);
        }

        /* ========================================================
           Responsive
           ======================================================== */
        @@media (max-width: 1100px) {
            .topbar-status .status-chip.optional { display: none; }
        }
        @@media (max-width: 880px) {
            .sidebar { display: none; }
            main { padding: 1rem; }
        }
        @@media (max-width: 720px) {
            .topbar { padding: 0 0.85rem; gap: 0.5rem; }
            .topbar .callsign-chip { font-size: 0.78rem; padding: 0.15rem 0.45rem; }
            .topbar-actions a span.label { display: none; }
        }
    </style>
</head>
<body>
    @if (hasShell)
    {
        @if (!TxGate.TxAllowed)
        {
            <div class="tx-banner-stop" role="alert">
                <span class="icon" aria-hidden="true"></span>
                <span class="label">TX stopped</span>
                <span class="reason">@TxGate.BlockReason</span>
                @if (!TxGate.LocalAllowed)
                {
                    <form method="post" action="/TxControl/resume" class="tx-stop-inline-form">
                        <button type="submit">Resume TX</button>
                    </form>
                }
            </div>
        }
        <header class="topbar">
            <a class="brand" href="/" title="DAPPS overview">
                <span class="brand-mark" aria-hidden="true"></span>
                <span class="brand-name">DAPPS</span>
            </a>
            <span class="callsign-chip" title="this node's callsign">@callsign</span>

            <div class="topbar-status" id="topbar-status">
                <span class="status-chip" id="ts-node" title="packet node link state">
                    <span class="led"></span>
                    <span class="lbl">Node</span>
                    <span class="v" id="ts-node-v">checking</span>
                </span>
                <span class="status-chip" id="ts-mqtt" title="embedded MQTT broker">
                    <span class="led"></span>
                    <span class="lbl">MQTT</span>
                    <span class="v" id="ts-mqtt-v">-</span>
                </span>
                <span class="status-chip optional" id="ts-air" title="discovery airtime - last hour">
                    <span class="lbl">Airtime</span>
                    <span class="gauge"><span class="bar"><span class="fill"></span></span></span>
                    <span class="v" id="ts-air-v">0%</span>
                </span>
                <span class="status-chip optional" id="ts-version" title="release vs latest on GitHub">
                    <span class="lbl">Build</span>
                    <span class="v" id="ts-version-v">-</span>
                </span>
            </div>

            <span class="topbar-spacer"></span>

            <div class="topbar-actions">
                @if (TxGate.TxAllowed)
                {
                    <form method="post" action="/TxControl/stop" class="tx-stop-inline-form">
                        <button type="submit" class="tx-killbtn" title="Stop all transmissions immediately">
                            <span class="led"></span> Stop TX
                        </button>
                    </form>
                }
                <button type="button" class="theme-toggle" id="theme-toggle" title="Toggle theme">
                    <span class="knob"></span><span class="label" id="theme-label">dark</span>
                </button>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Logout" title="Sign out"><span class="label">Sign out</span></a>
                }
            </div>
        </header>
        <div class="shell">
            <aside class="sidebar" id="sidebar">
                <div class="nav-group">
                    <div class="nav-section">Operate</div>
                    <a href="/" class="nav-link @(active == "overview" ? "active" : "")">
                        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 4l9 8" /><path d="M5 10v10h14V10" /></svg>
                        Overview
                    </a>
                    <a href="/Messages" class="nav-link @(active == "messages" ? "active" : "")">
                        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16v10H8l-4 4z" /></svg>
                        Messages
                    </a>
                    <a href="/Topology" class="nav-link @(active == "topology" ? "active" : "")">
                        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="2" /><circle cx="18" cy="6" r="2" /><circle cx="12" cy="18" r="2" /><path d="M7.5 7.5l3 8.7M16.5 7.5l-3 8.7M8 6h8" /></svg>
                        Topology
                    </a>
                    <a href="/Diagnostics" class="nav-link @(active == "diagnostics" ? "active" : "")">
                        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h3l3-7 4 14 3-7h5" /></svg>
                        Diagnostics
                    </a>
                    <div class="nav-section">Tools</div>
                    <a href="/Compose" class="nav-link @(active == "compose" ? "active" : "")">
                        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20l4-1L20 7l-3-3L5 16l-1 4z" /></svg>
                        Compose
                    </a>
                    <a href="/Streams" class="nav-link @(active == "streams" ? "active" : "")">
                        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7c4 0 4 3 8 3s4-3 8-3M4 12c4 0 4 3 8 3s4-3 8-3M4 17c4 0 4 3 8 3s4-3 8-3" /></svg>
                        Streams
                    </a>
                    <div class="nav-section">System</div>
                    <a href="/Settings" class="nav-link @(active == "settings" ? "active" : "")">
                        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1-1.5 1.7 1.7 0 0 0-1.9.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.9 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.5-1 1.7 1.7 0 0 0-.3-1.9l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.9.3h.1a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.9-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.9v.1a1.7 1.7 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z" /></svg>
                        Settings
                    </a>
                </div>
            </aside>
            <main>
                @if (!string.IsNullOrEmpty(pageTitle))
                {
                    <div class="page-head">
                        <div>
                            <h1>@pageTitle</h1>
                            @if (!string.IsNullOrEmpty(pageSubtitle))
                            {
                                <div class="subtitle">@pageSubtitle</div>
                            }
                        </div>
                        @if (IsSectionDefined("Actions"))
                        {
                            <div class="actions">@await RenderSectionAsync("Actions", required: false)</div>
                        }
                    </div>
                }
                @if (IsSectionDefined("Tabs"))
                {
                    <nav class="tabs">@await RenderSectionAsync("Tabs", required: false)</nav>
                }
                @RenderBody()
            </main>
        </div>

        <script>
            // --- Theme toggle ---
            (function () {
                const btn = document.getElementById('theme-toggle');
                const lbl = document.getElementById('theme-label');
                const html = document.documentElement;
                const stored = localStorage.getItem('dapps-theme');
                if (stored === 'light' || stored === 'dark') {
                    html.dataset.theme = stored;
                    if (lbl) lbl.textContent = stored;
                }
                if (btn) {
                    btn.addEventListener('click', () => {
                        const next = html.dataset.theme === 'light' ? 'dark' : 'light';
                        html.dataset.theme = next;
                        localStorage.setItem('dapps-theme', next);
                        if (lbl) lbl.textContent = next;
                    });
                }
            })();

            // --- Topbar status: drives Node / MQTT / Airtime / Build chips
            //     from a single /Operational?full=true poll. Also exposes
            //     window.__dappsSnap for any page that wants the snapshot
            //     instead of polling itself. ---
            (function () {
                window.__dappsSnap = null;
                window.__dappsSnapListeners = [];
                window.dappsOnSnap = function (fn) {
                    window.__dappsSnapListeners.push(fn);
                    if (window.__dappsSnap) try { fn(window.__dappsSnap); } catch (e) { console.error(e); }
                };
                const set = (id, txt) => { const el = document.getElementById(id); if (el) el.textContent = txt; };
                const led = (chip, cls) => {
                    if (!chip) return;
                    const l = chip.querySelector('.led');
                    if (!l) return;
                    l.classList.remove('on', 'warn', 'err', 'live');
                    if (cls) l.classList.add(cls);
                };
                async function pull() {
                    try {
                        const res = await fetch('/Operational?full=true', { credentials: 'same-origin' });
                        if (!res.ok) return;
                        const s = await res.json();
                        window.__dappsSnap = s;

                        // Node chip - green when reachable, red otherwise
                        const tsNode = document.getElementById('ts-node');
                        led(tsNode, s.nodeReachable ? 'on' : 'err');
                        set('ts-node-v', s.nodeReachable ? 'reachable' : 'unreachable');

                        // MQTT chip - if heartbeat enabled and no errors, on
                        const tsMqtt = document.getElementById('ts-mqtt');
                        led(tsMqtt, s.mqttBrokerUp ? 'on' : 'warn');
                        set('ts-mqtt-v', s.mqttBrokerUp ? 'up' : 'down');

                        // Airtime gauge
                        const used = s.airtimeConsumedSecondsLastHour || 0;
                        const budget = s.airtimeBudgetSecondsPerHour || 0;
                        const tsAir = document.getElementById('ts-air');
                        const fill = tsAir ? tsAir.querySelector('.fill') : null;
                        if (fill) {
                            if (budget <= 0) {
                                fill.style.transform = 'scaleX(0)';
                                set('ts-air-v', `${Math.round(used)}s`);
                                tsAir.querySelector('.gauge').classList.remove('warn', 'err');
                            } else {
                                const ratio = Math.min(1.5, used / budget);
                                fill.style.transform = `scaleX(${Math.min(1, ratio)})`;
                                const pct = Math.round((used / budget) * 100);
                                set('ts-air-v', `${pct}%`);
                                const g = tsAir.querySelector('.gauge');
                                g.classList.toggle('err', ratio >= 1);
                                g.classList.toggle('warn', ratio >= 0.9 && ratio < 1);
                            }
                        }

                        // Build chip
                        const upd = s.tables?.update ?? null;
                        const tsVer = document.getElementById('ts-version');
                        if (upd) {
                            if (upd.isDevBuild) {
                                set('ts-version-v', upd.current || s.version);
                                led(tsVer, 'warn');
                            } else if (upd.isAvailable && upd.latest) {
                                set('ts-version-v', `v${upd.current} -> v${upd.latest}`);
                                led(tsVer, 'warn');
                            } else {
                                set('ts-version-v', `v${upd.current || s.version}`);
                                led(tsVer, 'on');
                            }
                        } else {
                            set('ts-version-v', `v${s.version}`);
                            led(tsVer, null);
                        }

                        for (const fn of window.__dappsSnapListeners) {
                            try { fn(s); } catch (e) { console.error(e); }
                        }
                    } catch { /* keep last cached */ }
                }
                pull();
                setInterval(pull, 5000);
                window.dappsRefreshSnap = pull;
            })();
        </script>
    }
    else
    {
        @RenderBody()
    }
</body>
</html>
