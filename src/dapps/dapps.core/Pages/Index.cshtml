                    return;
                }
                body.innerHTML = rows.map(r => {
                    const droppedAt = new Date(r.droppedAt);
                    const lived = Math.max(0, Math.floor(
                        (droppedAt.getTime() - new Date(r.createdAt).getTime()) / 1000));
                    const ts = droppedAt.toISOString().substring(11, 19);
                    const droppedSecsAgo = Math.max(0, Math.floor(
                        (Date.now() - droppedAt.getTime()) / 1000));
                    return `<tr>` +
                        `<td><code>${ts}</code> <span class="muted">(${fmtAgo(droppedSecsAgo)} ago)</span></td>` +
