@page
@model StreamsModel
@{
    ViewData["Title"] = $"DAPPS - streams ({Model.Options.Callsign})";
    ViewData["Active"] = "streams";
    ViewData["PageTitle"] = "Streams";
    ViewData["PageSubtitle"] = "Per-(remote, stream-id) state for opt-in message ordering. Set StreamId on outbound submissions to opt in. Receive cursors gate local delivery on the next-expected sequence.";
    var now = DateTime.UtcNow;
}

<div class="panel">
    <h3>Send state</h3>
    <p class="panel-sub">Monotonic <code>sn=</code> counters minted for each (local, remote, stream) tuple.</p>
    @if (Model.SendStates.Count == 0)
    {
        <div class="empty">No outbound streams have been used yet.</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Local</th><th>Remote</th><th>Stream id</th>
                    <th class="numeric">Next sn</th><th>Updated</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.SendStates)
                {
                    <tr>
                        <td><code>@s.LocalCallsign</code></td>
                        <td><code>@s.RemoteCallsign</code></td>
                        <td><code>@s.StreamId</code></td>
                        <td class="numeric">@s.NextSeq</td>
                        <td>@s.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")Z</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="panel" style="margin-top: 1rem;">
    <h3>Receive state</h3>
    <p class="panel-sub">
        Highlighted rows have parked messages awaiting an earlier <code>sn</code>. Strict streams (<code>gt=0</code>) show no gap deadline; in timeout mode the deadline is when the gap sweeper (1-minute cadence) skips past the missing seq and drains.
    </p>
    @if (Model.RecvStates.Count == 0)
    {
        <div class="empty">No inbound streams have been seen yet.</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Sender</th><th>Stream id</th>
                    <th class="numeric">Next sn</th><th class="numeric">Pending</th>
                    <th>Oldest pending</th><th>Gap deadline</th><th>Last seen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.RecvStates)
                {
                    var stalled = row.PendingCount > 0;
                    <tr class="@(stalled ? "warn" : "")">
                        <td><code>@row.State.SenderCallsign</code></td>
                        <td><code>@row.State.StreamId</code></td>
                        <td class="numeric">@row.State.NextExpectedSeq</td>
                        <td class="numeric">@row.PendingCount</td>
                        <td>
                            @if (row.OldestPendingAt is { } oldest)
                            {
                                @($"{(int)(now - oldest).TotalSeconds}s ago")
                            }
                            else
                            {
                                @:-
                            }
                        </td>
                        <td>
                            @if (row.State.GapDeadline == DateTime.MinValue)
                            {
                                <span class="muted">-</span>
                            }
                            else
                            {
                                @row.State.GapDeadline.ToString("yyyy-MM-dd HH:mm:ss")
                                @:Z
                            }
                        </td>
                        <td>@row.State.LastReceivedAt.ToString("yyyy-MM-dd HH:mm:ss")Z</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
