@page
@model IndexModel
@{
    ViewData["Title"] = $"DAPPS - {Model.Options.Callsign}";
    ViewData["Active"] = "overview";
    ViewData["PageTitle"] = "Overview";
    ViewData["PageSubtitle"] = "Node health, queue at a glance, and quick actions. Live status updates every 5 seconds.";
}

@section Actions {
    <a class="btn secondary sm" href="/Diagnostics">Audit log</a>
    <a class="btn sm" href="/Compose">Compose message</a>
}

@if (Model.FlashOk is not null)
{
    <div class="ok-banner">@Model.FlashOk</div>
}
@if (Model.FlashError is not null)
{
    <div class="err-banner">@Model.FlashError</div>
}

@if (string.IsNullOrWhiteSpace(Model.Options.Callsign) || string.Equals(Model.Options.Callsign, "N0CALL", StringComparison.OrdinalIgnoreCase))
{
    <div class="info-banner">
        Looks like a fresh install. Set your callsign and packet-node bearer in <a href="/Settings">Settings</a> to start beaconing.
    </div>
}

<!-- Hero status row -->
<div class="grid">
    <div class="tile is-on" id="hero-node">
        <div class="head">
            <span class="led on"></span>
            <span class="lbl">Packet node</span>
            <span class="pill" id="hero-node-pill">checking</span>
        </div>
        <div class="v" id="hero-node-v">
            @{
                var bearerLabel = string.Equals(Model.Options.NodeBearer, "rhpv2", StringComparison.OrdinalIgnoreCase) ? "RHPv2" : "AGW";
                var nodePort = string.Equals(Model.Options.NodeBearer, "rhpv2", StringComparison.OrdinalIgnoreCase)
                    ? (Model.Options.RhpPort > 0 ? Model.Options.RhpPort : 9000)
                    : Model.Options.AgwPort;
            }
            @bearerLabel @Model.Options.NodeHost:@nodePort
        </div>
        <div class="sub" id="hero-node-sub">
            What DAPPS rides on. Probe answers means TCP connect succeeded.
        </div>
    </div>

    <div class="tile" id="hero-mqtt">
        <div class="head">
            <span class="led"></span>
            <span class="lbl">MQTT broker</span>
            <span class="pill" id="hero-mqtt-pill">-</span>
        </div>
        <div class="v" id="hero-mqtt-v">localhost:@Model.Options.MqttPort</div>
        <div class="sub">Apps subscribe to <code>dapps/in/&lt;app&gt;</code> here.</div>
    </div>

    <div class="tile @(Model.TxAllowed ? "is-on" : "is-err")" id="hero-tx">
        <div class="head">
            <span class="led @(Model.TxAllowed ? "on" : "err")"></span>
            <span class="lbl">TX gate</span>
            @if (Model.TxAllowed)
            {
                <span class="pill ok">live</span>
            }
            else
            {
                <span class="pill err">stopped</span>
            }
        </div>
        <div class="v">@(Model.TxAllowed ? "transmitting" : "blocked")</div>
        <div class="sub">@(Model.TxAllowed ? "Beacons, probes, and forwards are firing as scheduled." : (Model.TxBlockReason ?? "Operator stopped TX."))</div>
    </div>

    <div class="tile" id="hero-update">
        <div class="head">
            <span class="led" id="hero-update-led"></span>
            <span class="lbl">Build</span>
            <span class="pill" id="hero-update-pill">-</span>
        </div>
        <div class="v" id="hero-update-v">checking</div>
        <div class="sub" id="hero-update-sub">
            <a href="#" id="hero-update-action" class="link-btn" style="display:none;">Apply update</a>
            <span id="hero-update-meta" class="muted">checking GitHub</span>
        </div>
    </div>
</div>

<!-- Activity + decision ticker -->
<div class="grid-2" style="margin-top: 1rem;">
    <div class="sparkbox">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom: 0.4rem;">
            <strong style="font-size: 0.82rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em;">Activity (forwards/min)</strong>
            <span class="muted" id="spark-summary" style="font-size: 0.78rem;">tracking since reload</span>
        </div>
        <svg class="spark-svg" id="spark" viewBox="0 0 200 60" preserveAspectRatio="none" aria-hidden="true">
            <defs>
                <linearGradient id="sparkfill" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="var(--signal)" stop-opacity="0.45" />
                    <stop offset="100%" stop-color="var(--signal)" stop-opacity="0" />
                </linearGradient>
            </defs>
            <path id="spark-area" d="" fill="url(#sparkfill)" />
            <path id="spark-line" d="" fill="none" stroke="var(--signal)" stroke-width="1.5" />
        </svg>
        <div class="spark-meta">
            <span><span class="led on" style="vertical-align: middle;"></span> <span id="spark-now">0</span> /min now</span>
            <span><span id="spark-lifetime">0</span> forwards since boot</span>
        </div>
    </div>
    <div class="panel" style="padding: 0.75rem 0.85rem;">
        <div style="display:flex; align-items:center; justify-content:space-between;">
            <strong style="font-size: 0.82rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em;">Recent decisions</strong>
            <span class="muted" style="font-size: 0.78rem;">last 20 events</span>
        </div>
        <div class="ticker" id="ticker">
            <div class="row"><span class="t">-</span><span class="k">waiting</span><span class="m">for events from /Operational</span></div>
        </div>
    </div>
</div>

<!-- Queue + Inbox summary -->
<div class="grid-3" style="margin-top: 1.25rem;">
    <div class="panel">
        <h3>Outbound queue</h3>
        <p class="panel-sub">Messages addressed elsewhere. Forwarder ticks every 5 s.</p>
        <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 0.5rem;">
            <div class="card" style="padding: 0.7rem 0.85rem;"><div class="label">Pending</div><div class="value" id="ov-pending-out">-</div></div>
            <div class="card" style="padding: 0.7rem 0.85rem;"><div class="label">Forwards (boot)</div><div class="value" id="ov-fwd-success">-</div></div>
        </div>
        <div class="card-actions"><a class="btn secondary sm" href="/Messages?tab=outbound">Inspect outbound</a></div>
    </div>
    <div class="panel">
        <h3>Local inbox</h3>
        <p class="panel-sub">Messages for apps on this node, awaiting MQTT/REST ack.</p>
        <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 0.5rem;">
            <div class="card" style="padding: 0.7rem 0.85rem;"><div class="label">Undelivered</div><div class="value" id="ov-pending-local">-</div></div>
            <div class="card" style="padding: 0.7rem 0.85rem;"><div class="label">Total tracked</div><div class="value" id="ov-total">-</div></div>
        </div>
        <div class="card-actions"><a class="btn secondary sm" href="/Messages?tab=inbox">Inspect inbox</a><a class="btn ghost sm" href="/Messages?tab=live">Live arrivals</a></div>
    </div>
    <div class="panel">
        <h3>Discovery airtime</h3>
        <p class="panel-sub">Trailing-hour discovery TX vs. budget. Beacons defer when full.</p>
        <div class="card" style="padding: 0.7rem 0.85rem;">
            <div class="label" id="ov-air-label">Used</div>
            <div class="value" id="ov-air-value">-</div>
            <div class="card-actions" style="margin-top: 0.6rem;">
                <span class="gauge" style="width: 100%;"><span class="bar"><span class="fill" id="ov-air-fill"></span></span></span>
            </div>
            <div class="caption" id="ov-air-caption">budget set in Settings -> Discovery</div>
        </div>
    </div>
</div>

<!-- Needs attention -->
<h2>Needs attention</h2>
<div id="alerts" class="grid">
    <div class="empty" id="alerts-empty">Nothing flagged. The node is happy.</div>
</div>

<!-- Quick test send -->
<h2>Quick send</h2>
<form class="panel" method="post" asp-page-handler="Send">
    <p class="panel-sub">Submit a one-off message via the same code path your apps use, without touching MQTT. Use this to verify a hop end-to-end.</p>
    <div class="field-grid">
        <div class="field">
            <label for="App">App</label>
            <input id="App" type="text" name="@nameof(IndexModel.Send).@nameof(IndexModel.SendForm.App)" value="@Model.Send.App" placeholder="mail" required />
            <span class="hint">application slug, e.g. <code>mail</code> or <code>chat</code></span>
        </div>
        <div class="field">
            <label for="Destination">Destination callsign</label>
            <input id="Destination" type="text" name="@nameof(IndexModel.Send).@nameof(IndexModel.SendForm.Destination)" value="@Model.Send.Destination" placeholder="M0LTE-1" required />
            <span class="hint">case-insensitive, normalised to upper-case before submit</span>
        </div>
        <div class="field" style="grid-column: 1 / -1;">
            <label for="Payload">Payload (UTF-8 text)</label>
            <input id="Payload" type="text" name="@nameof(IndexModel.Send).@nameof(IndexModel.SendForm.Payload)" value="@Model.Send.Payload" placeholder="hello world" />
            <span class="hint">For binary payloads or fine-grained control use <a href="/Compose">Compose</a>.</span>
        </div>
    </div>
    <div style="margin-top: 0.85rem; display: flex; gap: 0.5rem;">
        <button class="btn" type="submit">Submit to queue</button>
        <a class="btn ghost" href="/Compose">Open full compose</a>
    </div>
</form>

<script>
    (function () {
        // --- Hero state from snapshot ---
        const set = (id, txt) => { const el = document.getElementById(id); if (el != null) el.textContent = txt; };
        const setHTML = (id, txt) => { const el = document.getElementById(id); if (el != null) el.innerHTML = txt; };
        const fmtAgo = (iso) => {
            if (!iso) return '-';
            const s = Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 1000));
            if (s < 90) return `${s}s ago`;
            if (s < 5400) return `${Math.floor(s / 60)}m ago`;
            if (s < 129600) return `${Math.floor(s / 3600)}h ago`;
            return `${Math.floor(s / 86400)}d ago`;
        };
        const escape = (s) => String(s ?? '').replace(/[&<>"']/g, c =>
            ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

        // --- Sparkline state ---
        const ringSize = 60;        // 1 sample / 5s = last 5 minutes visible
        const ring = new Array(ringSize).fill(null);
        let lastForwardSuccess = null;
        function pushSample(value) {
            ring.shift(); ring.push(value);
            renderSpark();
        }
        function renderSpark() {
            const valid = ring.filter(v => v != null);
            const max = Math.max(1, ...valid);
            const w = 200, h = 60;
            const step = w / (ringSize - 1);
            let line = '', area = '';
            for (let i = 0; i < ringSize; i++) {
                const v = ring[i];
                if (v == null) continue;
                const x = (i * step).toFixed(2);
                const y = (h - (v / max) * (h - 4) - 2).toFixed(2);
                line += (line ? ' L' : 'M') + x + ' ' + y;
            }
            if (line) {
                area = line + ` L${w} ${h} L0 ${h} Z`;
            }
            const lineEl = document.getElementById('spark-line');
            const areaEl = document.getElementById('spark-area');
            if (lineEl) lineEl.setAttribute('d', line);
            if (areaEl) areaEl.setAttribute('d', area);
        }

        // --- Decision ticker ---
        function renderTicker(events) {
            const t = document.getElementById('ticker');
            if (!t) return;
            if (!events || !events.length) {
                t.innerHTML = '<div class="row"><span class="t">-</span><span class="k">quiet</span><span class="m">no recent decisions</span></div>';
                return;
            }
            const rows = events.slice(0, 20).map(ev => {
                const k = (ev.kind || '').toString();
                let kc = '';
                if (k.endsWith('.ok') || k.includes('learned')) kc = 'ok';
                else if (k.includes('fail') || k.includes('drop') || k.includes('expired') || k.includes('mismatch')) kc = 'err';
                else if (k.includes('skip') || k.includes('budget') || k.includes('warn')) kc = 'warn';
                const t = ev.atUtc ? new Date(ev.atUtc).toISOString().substring(11, 19) : '?';
                return `<div class="row"><span class="t">${escape(t)}</span><span class="k ${kc}">${escape(k)}</span><span class="m" title="${escape(ev.detail || '')}">${escape(ev.detail || '')}</span></div>`;
            }).join('');
            t.innerHTML = rows;
        }

        // --- Alerts compute ---
        function computeAlerts(s) {
            const out = [];
            if (!s.nodeReachable) {
                out.push({ tone: 'err', title: 'Packet node not answering',
                          body: 'TCP connect to the bearer port failed. Check linbpq/xrouter is running and bearer port matches Settings.' });
            }
            if (!s.callsignConfigured) {
                out.push({ tone: 'warn', title: 'Callsign not set',
                          body: 'DAPPS will not transmit until a callsign is configured.' });
            }
            if (s.neighbourCount === 0 && s.discoveredPeerCount === 0) {
                out.push({ tone: 'warn', title: 'No neighbours and no discovered peers',
                          body: 'Nothing to forward to. Add a neighbour in Topology or enable discovery.' });
            }
            const dropped = s.tables?.dropped ?? [];
            if (dropped.length > 0) {
                out.push({ tone: 'warn', title: `${dropped.length} message(s) dropped recently`,
                          body: 'See Messages -> Dropped for the reason on each.' });
            }
            const probedBad = (s.tables?.probedNodes ?? []).filter(p => (p.consecutiveFailures || 0) >= 3);
            if (probedBad.length > 0) {
                out.push({ tone: 'warn', title: `${probedBad.length} probed peer(s) failing`,
                          body: probedBad.slice(0, 3).map(p => p.callsign).join(', ') + (probedBad.length > 3 ? ', ...' : '') + ' - 3 or more consecutive failures.' });
            }
            const used = s.airtimeConsumedSecondsLastHour || 0;
            const budget = s.airtimeBudgetSecondsPerHour || 0;
            if (budget > 0 && used / budget >= 0.9) {
                out.push({ tone: used / budget >= 1 ? 'err' : 'warn',
                          title: `Discovery airtime ${used / budget >= 1 ? 'exhausted' : 'almost exhausted'}`,
                          body: `${Math.round(used)}s of ${budget}s used in the last hour.` });
            }
            const upd = s.tables?.update;
            if (upd && upd.isAvailable && upd.latest && !upd.isDevBuild) {
                out.push({ tone: 'info', title: `Update available: v${upd.latest}`,
                          body: 'Apply from the build chip on the top bar or from Overview hero.' });
            }
            return out;
        }
        function renderAlerts(s) {
            const arr = computeAlerts(s);
            const c = document.getElementById('alerts');
            const empty = document.getElementById('alerts-empty');
            if (!c) return;
            if (arr.length === 0) {
                c.innerHTML = '<div class="empty">Nothing flagged. The node is happy.</div>';
                return;
            }
            c.innerHTML = arr.map(a => {
                const tone = a.tone || 'info';
                const led = tone === 'err' ? 'err' : (tone === 'warn' ? 'warn' : 'on');
                return `<div class="tile is-${tone === 'err' ? 'err' : (tone === 'warn' ? 'warn' : 'on')}">
                    <div class="head"><span class="led ${led}"></span><span class="lbl">${escape(a.title)}</span></div>
                    <div class="sub" style="font-size: 0.85rem;">${escape(a.body)}</div>
                </div>`;
            }).join('');
        }

        // --- Apply snapshot ---
        let lastSampleAt = 0;
        function apply(s) {
            // Hero - node
            const nodeTile = document.getElementById('hero-node');
            if (nodeTile) {
                nodeTile.classList.toggle('is-on', !!s.nodeReachable);
                nodeTile.classList.toggle('is-err', !s.nodeReachable);
                const led = nodeTile.querySelector('.led');
                led.classList.remove('on', 'err'); led.classList.add(s.nodeReachable ? 'on' : 'err');
            }
            set('hero-node-pill', s.nodeReachable ? 'reachable' : 'down');
            const pill = document.getElementById('hero-node-pill');
            if (pill) { pill.classList.remove('ok','err','warn'); pill.classList.add(s.nodeReachable ? 'ok' : 'err'); }

            // Hero - MQTT
            const mqttTile = document.getElementById('hero-mqtt');
            if (mqttTile) {
                mqttTile.classList.toggle('is-on', !!s.mqttBrokerUp);
                mqttTile.classList.toggle('is-warn', !s.mqttBrokerUp);
                const led = mqttTile.querySelector('.led');
                led.classList.remove('on', 'warn'); led.classList.add(s.mqttBrokerUp ? 'on' : 'warn');
            }
            const mqttPill = document.getElementById('hero-mqtt-pill');
            if (mqttPill) {
                mqttPill.classList.remove('ok','warn');
                mqttPill.classList.add(s.mqttBrokerUp ? 'ok' : 'warn');
                mqttPill.textContent = s.mqttBrokerUp ? 'up' : 'down';
            }

            // Hero - update
            const upd = s.tables?.update ?? null;
            const updLed = document.getElementById('hero-update-led');
            const updPill = document.getElementById('hero-update-pill');
            if (upd) {
                if (upd.isDevBuild) {
                    set('hero-update-v', upd.current);
                    updLed.classList.remove('on','warn','err'); updLed.classList.add('warn');
                    updPill.classList.remove('ok','warn'); updPill.classList.add('warn');
                    updPill.textContent = 'dev';
                    set('hero-update-meta', 'dev builds do not auto-update');
                } else if (upd.isAvailable && upd.latest) {
                    set('hero-update-v', `v${upd.current} -> v${upd.latest}`);
                    updLed.classList.remove('on','err'); updLed.classList.add('warn');
                    updPill.classList.remove('ok','err'); updPill.classList.add('warn');
                    updPill.textContent = 'available';
                    set('hero-update-meta', upd.fetchedAt ? `last checked ${fmtAgo(upd.fetchedAt)}` : 'release fetched');
                    const action = document.getElementById('hero-update-action');
                    if (action) {
                        action.style.display = '';
                        action.textContent = 'Apply update';
                        action.onclick = async (ev) => {
                            ev.preventDefault();
                            if (!confirm(`Apply v${upd.latest}? Dapps will restart and roll back if it fails to come up.`)) return;
                            await fetch('/Update/apply', { method: 'POST' });
                            await window.dappsRefreshSnap?.();
                        };
                    }
                } else {
                    set('hero-update-v', `v${upd.current}`);
                    updLed.classList.remove('warn','err'); updLed.classList.add('on');
                    updPill.classList.remove('warn','err'); updPill.classList.add('ok');
                    updPill.textContent = 'current';
                    set('hero-update-meta', upd.fetchedAt ? `up to date - checked ${fmtAgo(upd.fetchedAt)}` : 'up to date');
                    const action = document.getElementById('hero-update-action');
                    if (action) action.style.display = 'none';
                }
            }

            // Sparkline + counters
            const successDelta = (lastForwardSuccess == null) ? 0 : Math.max(0, (s.forwardSuccess || 0) - lastForwardSuccess);
            lastForwardSuccess = s.forwardSuccess || 0;
            const now = Date.now();
            if (lastSampleAt === 0 || now - lastSampleAt > 4000) {
                pushSample(successDelta * 12); // scale 5s tick to /minute
                lastSampleAt = now;
            }
            set('spark-now', successDelta * 12);
            set('spark-lifetime', s.forwardSuccess || 0);
            set('spark-summary', s.lastForwardSuccessAt ? `last forward ${fmtAgo(s.lastForwardSuccessAt)}` : 'no forwards yet');

            renderTicker(s.recentEvents);

            // Queue summary
            set('ov-pending-out', s.pendingOutboundCount ?? '-');
            set('ov-fwd-success', s.forwardSuccess ?? '-');
            set('ov-pending-local', s.undeliveredLocalCount ?? '-');
            set('ov-total', s.totalMessagesCount ?? '-');

            // Airtime panel
            const used = Math.round(s.airtimeConsumedSecondsLastHour || 0);
            const budget = s.airtimeBudgetSecondsPerHour || 0;
            const fill = document.getElementById('ov-air-fill');
            if (budget > 0) {
                const ratio = Math.min(1.5, used / budget);
                set('ov-air-value', `${Math.round((used / budget) * 100)}%`);
                set('ov-air-caption', `${used}s used of ${budget}s/hour budget`);
                if (fill) fill.style.transform = `scaleX(${Math.min(1, ratio)})`;
            } else {
                set('ov-air-value', `${used}s`);
                set('ov-air-caption', 'no budget set - all transmissions allowed');
                if (fill) fill.style.transform = 'scaleX(0)';
            }

            renderAlerts(s);
        }

        if (window.__dappsSnap) apply(window.__dappsSnap);
        if (window.dappsOnSnap) window.dappsOnSnap(apply);
    })();
</script>
