@page
@model IndexModel
@{
    ViewData["Title"] = $"DAPPS — {Model.Options.Callsign}";
}

<header class="app-header">
    <span class="brand">
        <span class="dot"></span>
        DAPPS
        <span class="callsign">@Model.Options.Callsign</span>
    </span>
    <span id="version-pill" class="pill" style="display:none"></span>
    <span class="spacer"></span>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a href="/Logout" class="signout">Sign out</a>
    }
</header>

<main>

@if (Model.FlashOk is not null)
{
    <div class="ok-banner">@Model.FlashOk</div>
}
@if (Model.FlashError is not null)
{
    <div class="err-banner">@Model.FlashError</div>
}

<script>
    // Poll /Events/version once on load and every 10 minutes after.
    // Renders one of three states into #version-pill in the header:
    //   - dev build:        "dev <sha>"   (info pill)
    //   - up to date:       "v0.X.Y"      (muted pill)
    //   - update available: "v0.X.Y → v0.X.Z available" (warn pill, links to release)
    (function () {
        const pill = document.getElementById('version-pill');
        if (!pill) return;
        async function poll() {
            try {
                const res = await fetch('/Events/version', { credentials: 'same-origin' });
                if (!res.ok) return;
                const v = await res.json();
                pill.style.display = '';
                pill.innerHTML = '';
                if (v.isDevBuild) {
                    pill.className = 'pill info';
                    pill.textContent = v.current;
                    pill.title = 'Running a dev build (not stamped from a release)';
                } else if (v.isAvailable && v.latest) {
                    pill.className = 'pill warn';
                    const a = document.createElement('a');
                    a.href = v.releaseUrl || '#';
                    a.target = '_blank';
                    a.rel = 'noopener';
                    a.style.color = 'inherit';
                    a.style.textDecoration = 'none';
                    a.textContent = `v${v.current} → v${v.latest} available`;
                    pill.appendChild(a);
                    pill.title = 'A newer release is on GitHub. Click for changelog.';
                } else {
                    pill.className = 'pill';
                    pill.textContent = `v${v.current}`;
                    pill.title = v.latest
                        ? `Latest on GitHub: v${v.latest}`
                        : 'Update check has not run yet';
                }
            } catch { /* swallow; try again next tick */ }
        }
        poll();
        setInterval(poll, 10 * 60 * 1000);
    })();
</script>

<h2>Node</h2>
<div class="grid">
    <div class="card">
        <div class="label">Callsign</div>
        <div class="value mono">@Model.Options.Callsign</div>
        <div class="caption">how this node identifies itself on the air</div>
    </div>
    <div class="card">
        <div class="label">BPQ AGW</div>
        <div class="value mono">
            <span>@Model.Options.NodeHost:@Model.Options.AgwPort</span>
            <span class="dot @(Model.BpqAgwReachable ? "ok" : "warn")" title="@(Model.BpqAgwReachable ? "reachable" : "unreachable")"></span>
        </div>
        <div class="caption">
            @(Model.BpqAgwReachable ? "TCP probe ok — BPQ accepting connections" : "TCP probe failed — start linbpq or check AGWPORT")
        </div>
    </div>
    <div class="card">
        <div class="label">Default outbound port</div>
        <div class="value mono">AGW @Model.Options.DefaultBpqPort → BPQ @(Model.Options.DefaultBpqPort + 1)</div>
        <div class="caption">port byte sent on outbound forwards when a neighbour has none set</div>
    </div>
    <div class="card">
        <div class="label">MQTT broker</div>
        <div class="value mono">localhost:@Model.Options.MqttPort</div>
        <div class="caption">apps subscribe here for inbound messages (see <code>dapps/in/&lt;app&gt;</code>)</div>
    </div>
    <div class="card">
        <div class="label">UDP datagram listener</div>
        <div class="value">
            @if (Model.Options.UdpListenPort > 0)
            {
                <span class="pill info">on :@Model.Options.UdpListenPort</span>
            }
            else
            {
                <span class="pill">disabled</span>
            }
        </div>
        <div class="caption">stand-in for MeshCore-style datagram backhaul; off in normal use</div>
    </div>
    <div class="card">
        <div class="label">App-interface auth</div>
        <div class="value">
            @if (Model.Options.AuthRequired)
            {
                <span class="pill ok">tokens required</span>
            }
            else
            {
                <span class="pill warn">open</span>
            }
        </div>
        <div class="caption">
            @if (Model.Options.AuthRequired)
            {
                <span>MQTT/REST clients must present a per-app token</span>
            }
            else
            {
                <span>any MQTT/REST client on this host can act as any app — fine for loopback, set tokens for shared nodes</span>
            }
        </div>
    </div>
</div>
<details class="edit-block">
    <summary>Edit configuration</summary>
    <p class="muted">Restart required for callsign, BPQ AGW host/port, MQTT port, UDP listener port to take effect.</p>
    <form class="edit-form" onsubmit="dappsSaveConfig(event)">
        <label>Callsign <input name="Callsign" value="@Model.Options.Callsign" required /></label>
        <label>Node host <input name="NodeHost" value="@Model.Options.NodeHost" required /></label>
        <label>AGW port <input name="AgwPort" type="number" min="1" max="65535" value="@Model.Options.AgwPort" required /></label>
        <label>Default BPQ port <input name="DefaultBpqPort" type="number" min="0" max="255" value="@Model.Options.DefaultBpqPort" required /></label>
        <label>MQTT port <input name="MqttPort" type="number" min="1" max="65535" value="@Model.Options.MqttPort" required /></label>
        <label>UDP listener port (0 = disabled) <input name="UdpListenPort" type="number" min="0" max="65535" value="@Model.Options.UdpListenPort" required /></label>
        <label class="checkbox-label"><input name="AuthRequired" type="checkbox" @(Model.Options.AuthRequired ? "checked" : "") /> App-interface auth required</label>
        <label class="checkbox-label"><input name="UpdateCheckEnabled" type="checkbox" @(Model.Options.UpdateCheckEnabled ? "checked" : "") /> Check GitHub for new releases</label>
        <label class="checkbox-label"><input name="ProbingEnabled" type="checkbox" @(Model.Options.ProbingEnabled ? "checked" : "") /> Probe known peers on a slow cadence (B6.1)</label>
        <label>Probe interval (hours) <input name="ProbeIntervalHours" type="number" min="1" max="168" value="@Model.Options.ProbeIntervalHours" required /></label>
        @{
            var ps = Model.Options.ProbeStrategy;
        }
        <label>Probe strategy (B7)
            <select name="ProbeStrategy">
                <option value="FixedInterval" selected="@(ps == dapps.core.Models.ProbeStrategy.FixedInterval)">Fixed interval</option>
                <option value="Overnight" selected="@(ps == dapps.core.Models.ProbeStrategy.Overnight)">Overnight (one sweep/day)</option>
                <option value="WhenQuiet" selected="@(ps == dapps.core.Models.ProbeStrategy.WhenQuiet)">When forwarder is quiet</option>
            </select>
        </label>
        <label>Overnight start hour (local) <input name="ProbeOvernightStartHour" type="number" min="0" max="23" value="@Model.Options.ProbeOvernightStartHour" required /></label>
        <label>Overnight end hour (local) <input name="ProbeOvernightEndHour" type="number" min="0" max="23" value="@Model.Options.ProbeOvernightEndHour" required /></label>
        <label>Quiet window (seconds) <input name="ProbeQuietWindowSeconds" type="number" min="1" max="86400" value="@Model.Options.ProbeQuietWindowSeconds" required /></label>
        <label class="checkbox-label"><input name="OpportunisticPollEnabled" type="checkbox" @(Model.Options.OpportunisticPollEnabled ? "checked" : "") /> Opportunistic poll on every push (F3a) — drain peers' mail at the end of every push session</label>
        <label class="checkbox-label"><input name="ScheduledPollEnabled" type="checkbox" @(Model.Options.ScheduledPollEnabled ? "checked" : "") /> Schedule periodic mail polls (F3b) — for nodes that don't push often</label>
        <label>Poll interval (hours) <input name="PollIntervalHours" type="number" min="1" max="168" value="@Model.Options.PollIntervalHours" required /></label>
        <label>Discovery airtime budget (seconds/hour, 0 = unlimited) (B7) <input name="DiscoveryAirtimeBudgetSecondsPerHour" type="number" min="0" max="3600" value="@Model.Options.DiscoveryAirtimeBudgetSecondsPerHour" required /></label>
        <button type="submit">Save</button>
    </form>
</details>
<details class="edit-block">
    <summary>Rotate admin password</summary>
    <form class="edit-form" onsubmit="dappsRotatePassword(event)">
        <label>New password <input name="password" type="password" required minlength="8" /></label>
        <button type="submit">Set</button>
    </form>
    <p class="muted">Existing session stays valid until logout or 90-day expiry — only future logins use the new password.</p>
</details>

<h2>Update <span id="upd-phase" class="pill">—</span></h2>
<p class="muted-inline">Plan C5.2 — triggered self-update via the privileged <code>dapps-updater.service</code>. Click <em>Apply update</em>; the unprivileged dapps writes a request marker to <code>/var/lib/dapps/update-requested</code> which the updater picks up on its next 60 s tick. The updater downloads the latest release for this RID, swaps it in, restarts dapps, watches for 60 s, and rolls back to <code>dapps.previous</code> if the new binary fails to stay up. <span class="muted">Status auto-refreshes every 5 s during a run.</span></p>
<div class="grid">
    <div class="card">
        <div class="label">Running</div>
        <div class="value mono"><span id="upd-current">—</span></div>
        <div class="caption" id="upd-rid-line">RID detected at build time</div>
    </div>
    <div class="card">
        <div class="label">Latest on GitHub</div>
        <div class="value mono"><span id="upd-latest">—</span></div>
        <div class="caption" id="upd-fetched">Update check has not run yet</div>
    </div>
    <div class="card">
        <div class="label">Last apply</div>
        <div class="value"><span id="upd-last">never</span></div>
        <div class="caption" id="upd-last-error"></div>
    </div>
    <div class="card">
        <div class="label">Action</div>
        <div class="value">
            <button id="upd-apply-btn" type="button" onclick="dappsApplyUpdate()" disabled>Apply update</button>
            <button id="upd-check-btn" type="button" onclick="dappsCheckNow()">Check now</button>
        </div>
        <div class="caption" id="upd-apply-caption">Need an available release to apply</div>
    </div>
</div>

<script>
    (function () {
        const phase = document.getElementById('upd-phase');
        const cur = document.getElementById('upd-current');
        const lat = document.getElementById('upd-latest');
        const fetched = document.getElementById('upd-fetched');
        const last = document.getElementById('upd-last');
        const lastErr = document.getElementById('upd-last-error');
        const btn = document.getElementById('upd-apply-btn');
        const cap = document.getElementById('upd-apply-caption');
        const fmtAgo = (iso) => {
            if (!iso) return '—';
            const s = Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 1000));
            if (s < 90) return `${s}s ago`;
            const m = Math.floor(s / 60);
            if (m < 90) return `${m}m ago`;
            const h = Math.floor(s / 3600);
            if (h < 36) return `${h}h ago`;
            return `${Math.floor(s / 86400)}d ago`;
        };
        const escape = (s) => String(s ?? '').replace(/[&<>"']/g, c =>
            ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
        const inProgress = (p) => ['Checking','Downloading','Swapping','Restarting','Verifying'].includes(p);
        async function poll() {
            try {
                const res = await fetch('/Update/status', { credentials: 'same-origin' });
                if (!res.ok) return;
                const s = await res.json();
                cur.textContent = s.isDevBuild ? `${s.current} (dev)` : `v${s.current}`;
                lat.textContent = s.latest ? `v${s.latest}` : '—';
                fetched.textContent = s.fetchedAt ? `last checked ${fmtAgo(s.fetchedAt)}` : 'Update check has not run yet';

                const lr = s.lastRun;
                if (!lr) {
                    last.textContent = 'never';
                    lastErr.textContent = '';
                    phase.className = 'pill';
                    phase.textContent = '—';
                } else {
                    // Phase is the enum name as a string (System.Text.Json
                    // would default to integers; UpdatePhase has a
                    // [JsonStringEnumConverter] attribute pinning the
                    // string shape — see UpdateStatus.cs).
                    const prettyPhase =
                        lr.phase === 'RolledBack' ? 'rolled back'
                        : (typeof lr.phase === 'string' ? lr.phase.toLowerCase() : '?');
                    last.textContent = `${prettyPhase} · ${fmtAgo(lr.updated_at)}`;
                    lastErr.textContent = lr.error ? `error: ${escape(lr.error)}` : '';
                    if (lr.phase === 'Success') { phase.className = 'pill ok'; phase.textContent = 'success'; }
                    else if (lr.phase === 'RolledBack') { phase.className = 'pill warn'; phase.textContent = 'rolled back'; }
                    else if (lr.phase === 'Failed') { phase.className = 'pill warn'; phase.textContent = 'failed'; }
                    else if (inProgress(lr.phase)) { phase.className = 'pill info'; phase.textContent = prettyPhase; }
                    else { phase.className = 'pill'; phase.textContent = prettyPhase; }
                }

                // Apply-button gating: needs a release available, and
                // not already running, and not already requested.
                const running = lr && inProgress(lr.phase);
                const canApply = s.isAvailable && !running && !s.requestPending;
                btn.disabled = !canApply;
                if (running) cap.textContent = 'Update in progress…';
                else if (s.requestPending) cap.textContent = 'Request queued — updater fires on next 60 s tick';
                else if (s.isDevBuild) cap.textContent = 'Dev builds do not auto-update';
                else if (!s.isAvailable && s.latest) cap.textContent = 'Already on the latest release';
                else if (!s.latest) cap.textContent = 'Need an available release to apply';
                else cap.textContent = 'Click to download + swap + restart';
            } catch { /* try again next tick */ }
        }
        async function dappsApplyUpdateFn() {
            if (!confirm('Apply the latest available update? Dapps will restart; if it fails to come up the previous binary is restored automatically.')) return;
            const res = await fetch('/Update/apply', { method: 'POST' });
            if (!res.ok && res.status !== 202 && res.status !== 204) {
                const text = await res.text();
                alert(`Apply failed (${res.status}): ${text}`);
                return;
            }
            poll();
        }
        async function dappsCheckNowFn() {
            // Force-refresh the cache. Cheap one-shot HTTPS to GitHub —
            // operators who just shipped a release hit this to see the
            // node notice within seconds rather than up to an hour.
            const btn = document.getElementById('upd-check-btn');
            btn.disabled = true;
            btn.textContent = 'Checking…';
            try {
                const res = await fetch('/Update/check', { method: 'POST' });
                if (!res.ok) {
                    const text = await res.text();
                    alert(`Check failed (${res.status}): ${text}`);
                    return;
                }
                await poll();
            } finally {
                btn.disabled = false;
                btn.textContent = 'Check now';
            }
        }
        window.dappsApplyUpdate = dappsApplyUpdateFn;
        window.dappsCheckNow = dappsCheckNowFn;
        poll();
        setInterval(poll, 5000);
    })();
</script>

<h2>Health</h2>
<p class="muted-inline">Process-lifetime counters + per-neighbour link state + a ring of recent forwarder / AGW / inbound-validation events. Resets on restart.</p>
<div class="grid">
    <div class="card">
        <div class="label">Forward attempts</div>
        <div class="value"><span id="m-forward-attempts">—</span></div>
        <div class="caption"><span id="m-forward-success">—</span> ok / <span id="m-forward-failure">—</span> failed</div>
    </div>
    <div class="card">
        <div class="label">TTL drops</div>
        <div class="value"><span id="m-ttl">—</span></div>
        <div class="caption">messages whose residual TTL hit zero in our queue</div>
    </div>
    <div class="card">
        <div class="label">No-route skips</div>
        <div class="value"><span id="m-noroute">—</span></div>
        <div class="caption">no neighbour / discovered peer / route-hint matched</div>
    </div>
    <div class="card">
        <div class="label">AGW reconnects</div>
        <div class="value"><span id="m-agw-reconnects">—</span></div>
        <div class="caption" id="m-agw-last">never</div>
    </div>
    <div class="card">
        <div class="label">Inbound L2 connects</div>
        <div class="value"><span id="m-inbound">—</span></div>
        <div class="caption">'C' frames dispatched to us by BPQ</div>
    </div>
    <div class="card">
        <div class="label">Hash mismatches</div>
        <div class="value"><span id="m-hash">—</span></div>
        <div class="caption">received payload whose sha1 didn't match the offered id</div>
    </div>
</div>

<h3 class="subhead">Per-neighbour link state</h3>
<table id="neigh-health-table">
    <thead>
        <tr>
            <th>Callsign</th>
            <th class="numeric">OK</th>
            <th class="numeric">Failed</th>
            <th>Last success</th>
            <th>Last failure</th>
            <th>Last error</th>
        </tr>
    </thead>
    <tbody id="neigh-health-body">
        <tr><td colspan="6" class="muted" style="text-align:center;">No forwarding activity yet.</td></tr>
    </tbody>
</table>

<h3 class="subhead">Recent activity</h3>
<table id="recent-events-table">
    <thead>
        <tr>
            <th>Time (UTC)</th>
            <th>Kind</th>
            <th>Detail</th>
        </tr>
    </thead>
    <tbody id="recent-events-body">
        <tr><td colspan="3" class="muted" style="text-align:center;">No events yet.</td></tr>
    </tbody>
</table>

<script>
    // Poll /Events/health every 5s; re-render counters, neighbour
    // table, and recent-events ring. Same DOM-swap pattern as the
    // queue tables — no full-page reload.
    (function () {
        const fmtAt = (iso) => iso ? new Date(iso).toISOString().replace('T', ' ').substring(0, 19) : '—';
        const fmtAgo = (iso) => {
            if (!iso) return '—';
            const s = Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 1000));
            if (s < 90) return `${s}s ago`;
            const m = Math.floor(s / 60);
            if (m < 90) return `${m}m ago`;
            const h = Math.floor(s / 3600);
            if (h < 36) return `${h}h ago`;
            return `${Math.floor(s / 86400)}d ago`;
        };
        const escape = (s) => String(s ?? '').replace(/[&<>"']/g, c =>
            ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
        const setText = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };

        async function poll() {
            try {
                const res = await fetch('/Events/health', { credentials: 'same-origin' });
                if (!res.ok) return;
                const d = await res.json();
                setText('m-forward-attempts', d.forwardAttempts);
                setText('m-forward-success', d.forwardSuccess);
                setText('m-forward-failure', d.forwardFailure);
                setText('m-ttl', d.ttlExpiredDrops);
                setText('m-noroute', d.noRouteSkips);
                setText('m-agw-reconnects', d.agwReconnects);
                setText('m-agw-last', d.agwLastReconnectAt ? `last ${fmtAgo(d.agwLastReconnectAt)}` : 'never');
                setText('m-inbound', d.inboundConnects);
                setText('m-hash', d.hashMismatches);

                const nbody = document.getElementById('neigh-health-body');
                if (!d.neighbours.length) {
                    nbody.innerHTML = '<tr><td colspan="6" class="muted" style="text-align:center;">No forwarding activity yet.</td></tr>';
                } else {
                    nbody.innerHTML = d.neighbours.map(n =>
                        `<tr>` +
                        `<td><code>${escape(n.callsign)}</code></td>` +
                        `<td class="numeric">${n.successCount}</td>` +
                        `<td class="numeric">${n.failureCount}</td>` +
                        `<td class="muted">${fmtAgo(n.lastSuccessAt)}</td>` +
                        `<td class="muted">${fmtAgo(n.lastFailureAt)}</td>` +
                        `<td class="muted">${escape(n.lastError ?? '—')}</td>` +
                        `</tr>`
                    ).join('');
                }

                const ebody = document.getElementById('recent-events-body');
                if (!d.recentEvents.length) {
                    ebody.innerHTML = '<tr><td colspan="3" class="muted" style="text-align:center;">No events yet.</td></tr>';
                } else {
                    ebody.innerHTML = d.recentEvents.map(e =>
                        `<tr>` +
                        `<td><code>${fmtAt(e.at).substring(11, 19)}</code></td>` +
                        `<td><span class="pill ${kindClass(e.kind)}">${escape(e.kind)}</span></td>` +
                        `<td class="muted">${escape(e.summary)}</td>` +
                        `</tr>`
                    ).join('');
                }
            } catch { /* try again next tick */ }
        }
        function kindClass(k) {
            if (k.endsWith('.ok')) return 'ok';
            if (k.endsWith('.fail') || k.endsWith('.mismatch') || k.endsWith('.expired') || k.endsWith('.none')) return 'warn';
            if (k.startsWith('agw.')) return 'info';
            return '';
        }
        poll();
        setInterval(poll, 5000);
    })();
</script>

<h2>Queue at a glance</h2>
<div class="grid">
    <div class="card">
        <div class="label">Total messages</div>
        <div class="value">@Model.TotalMessages</div>
        <div class="caption">all rows in the messages table, ever</div>
    </div>
    <div class="card">
        <div class="label">Pending outbound</div>
        <div class="value">@Model.PendingOutbound</div>
        <div class="caption">queued for forwarding to another node</div>
    </div>
    <div class="card">
        <div class="label">Undelivered local</div>
        <div class="value">@Model.UndeliveredLocal</div>
        <div class="caption">arrived for an app on this node, not yet ack'd</div>
    </div>
    <div class="card">
        <div class="label">Neighbours</div>
        <div class="value">@Model.NeighbourCount</div>
        <div class="caption">configured forwarding peers</div>
    </div>
</div>

<h2>Outbound queue <span id="outbound-count" class="pill @(Model.OutboundQueue.Count == 0 ? "" : "warn")">@Model.OutboundQueue.Count</span></h2>
<p class="muted-inline">Messages waiting to be forwarded to another node. The forwarder loop wakes periodically, picks one, and sends it via the cheapest reachable bearer. <span class="muted">Auto-refreshes every 5s.</span></p>
<table id="outbound-table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Destination</th>
            <th>From</th>
            <th class="numeric">Bytes</th>
            <th class="numeric">TTL</th>
            <th>Age</th>
        </tr>
    </thead>
    <tbody id="outbound-body">
    @if (Model.OutboundQueue.Count == 0)
    {
        <tr><td colspan="6" class="muted" style="text-align:center;">No outbound forwards in flight.</td></tr>
    }
    else
    {
        @foreach (var m in Model.OutboundQueue)
        {
            <tr>
                <td><code>@m.Id</code></td>
                <td><code>@m.Destination</code></td>
                <td><code>@m.SourceCallsign</code></td>
                <td class="numeric">@m.Payload.Length</td>
                <td class="numeric">@(m.Ttl?.ToString() ?? "—")</td>
                <td class="muted">@IndexModel.Age(m.CreatedAt)</td>
            </tr>
        }
    }
    </tbody>
</table>

<h2>Local inbox <span id="inbox-count" class="pill @(Model.LocalInbox.Count == 0 ? "" : "info")">@Model.LocalInbox.Count</span></h2>
<p class="muted-inline">Messages arrived for apps on this node, waiting for the app to ack via MQTT (<code>dapps/ack/&lt;app&gt;</code>) or REST.</p>
<table id="inbox-table">
    <thead>
        <tr>
            <th>Id</th>
            <th>App</th>
            <th>From</th>
            <th class="numeric">Bytes</th>
            <th class="numeric">TTL</th>
            <th>Age</th>
        </tr>
    </thead>
    <tbody id="inbox-body">
