@page
@model TransmissionsModel
@{
    ViewData["Title"] = $"DAPPS - transmissions audit ({Model.Options.Callsign})";
}

<header class="app-header">
    <span class="brand">
        <span class="dot"></span>
        DAPPS
        <span class="callsign">@Model.Options.Callsign</span>
        <span style="color: var(--text-muted); font-weight: 500; margin-left: 0.4rem;">-> transmissions audit</span>
    </span>
    <span class="spacer"></span>
    <a href="/">dashboard</a>
    <a href="/Inbound">inbound</a>
    <a href="/IHave">ihave</a>
    <a href="/Streams">streams</a>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a href="/Logout" class="signout">sign out</a>
    }
</header>

<main>
    <h2>Transmissions audit
        <span id="tx-status" class="pill">loading...</span>
    </h2>
    <p class="muted-inline">
        Persistent log of every outbound transmission this node has made: beacons, solicits,
        probes, message forwards, polls, acks, heartbeats. Each row has a <em>reason</em> field
        describing why the daemon decided to transmit. Polled from
        <code>/Transmissions</code>; retention controlled by
        <code>TransmissionAuditRetentionDays</code> (default 90).
    </p>

    <div class="tx-filters" style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: end; margin: 0.75rem 0 0.5rem;">
        <div>
            <label for="tx-kind" style="display:block; font-size: 0.8rem; color: var(--text-muted);">Kind</label>
            <select id="tx-kind" style="width: 13rem; padding: 0.3rem;">
                <option value="">all</option>
                <option value="beacon">beacon</option>
                <option value="solicit">solicit</option>
                <option value="solicit-reply">solicit-reply</option>
                <option value="probe">probe</option>
                <option value="probe-nodeprompt">probe-nodeprompt</option>
                <option value="forward">forward</option>
                <option value="forward-flood">forward-flood</option>
                <option value="poll">poll</option>
                <option value="rev-drain">rev-drain</option>
                <option value="ack">ack</option>
                <option value="nak">nak</option>
                <option value="heartbeat">heartbeat</option>
            </select>
        </div>
        <div>
            <label for="tx-target" style="display:block; font-size: 0.8rem; color: var(--text-muted);">Target callsign</label>
            <input id="tx-target" type="text" placeholder="e.g. M0LTE-1" style="width: 12rem;" />
        </div>
        <div style="display:flex; align-items:center; gap:0.4rem;">
            <input id="tx-failures" type="checkbox" />
            <label for="tx-failures" style="font-size: 0.85rem;">only failures</label>
        </div>
        <button class="btn" type="button" id="tx-refresh">Refresh</button>
        <span class="muted-inline" id="tx-count">-</span>
    </div>

    <table id="tx-table">
        <thead>
            <tr>
                <th style="width: 11rem;">When (UTC)</th>
                <th style="width: 9rem;">Kind</th>
                <th style="width: 4rem;">Bearer</th>
                <th style="width: 9rem;">Target</th>
                <th>Reason</th>
                <th class="numeric" style="width: 5rem;">Bytes</th>
                <th class="numeric" style="width: 5rem;">ms</th>
                <th style="width: 5rem;">OK?</th>
            </tr>
        </thead>
        <tbody id="tx-body">
            <tr><td colspan="8" class="muted" style="text-align: center;">loading...</td></tr>
        </tbody>
    </table>
</main>

<script>
    (function () {
        const tbody = document.getElementById('tx-body');
        const status = document.getElementById('tx-status');
        const counter = document.getElementById('tx-count');
        const kindSel = document.getElementById('tx-kind');
        const targetIn = document.getElementById('tx-target');
        const failuresChk = document.getElementById('tx-failures');
        const refreshBtn = document.getElementById('tx-refresh');

        const fmtAt = (iso) => {
            try { return new Date(iso).toISOString().replace('T', ' ').substring(0, 19); }
            catch { return iso ?? '-'; }
        };
        const escape = (s) => String(s ?? '').replace(/[&<>"']/g, c =>
            ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

        async function load() {
            status.textContent = 'loading...';
            status.className = 'pill';
            const params = new URLSearchParams();
            params.set('limit', '300');
            const k = kindSel.value;
            if (k) params.append('kind', k);
            const t = targetIn.value.trim();
            if (t) params.set('target', t);
            if (failuresChk.checked) params.set('onlyFailures', 'true');

            try {
                const res = await fetch('/Transmissions?' + params.toString(), { credentials: 'same-origin' });
                if (!res.ok) {
                    status.textContent = 'error';
                    status.className = 'pill warn';
                    tbody.innerHTML = `<tr><td colspan="8" class="muted" style="text-align: center;">HTTP ${res.status}</td></tr>`;
                    return;
                }
                const rows = await res.json();
                status.textContent = 'live';
                status.className = 'pill ok';
                counter.textContent = `${rows.length} row(s)`;

                if (rows.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" class="muted" style="text-align: center;">no transmissions match the filter</td></tr>';
                    return;
                }
                tbody.innerHTML = rows.map(r => {
                    const ok = r.success
                        ? '<span class="pill ok">ok</span>'
                        : '<span class="pill warn">' + escape(r.errorTag || 'fail') + '</span>';
                    return '<tr>'
                        + '<td>' + escape(fmtAt(r.at)) + '</td>'
                        + '<td><code>' + escape(r.kind) + '</code></td>'
                        + '<td>' + escape(r.bearer) + '</td>'
                        + '<td>' + (r.targetCallsign ? '<code>' + escape(r.targetCallsign) + '</code>' : '') + '</td>'
                        + '<td>' + escape(r.reason) + '</td>'
                        + '<td class="numeric">' + (r.bytes || '') + '</td>'
                        + '<td class="numeric">' + (r.durationMs || '') + '</td>'
                        + '<td>' + ok + '</td>'
                        + '</tr>';
                }).join('');
            } catch (e) {
                status.textContent = 'error';
                status.className = 'pill warn';
                tbody.innerHTML = `<tr><td colspan="8" class="muted" style="text-align: center;">${escape(e.message ?? e)}</td></tr>`;
            }
        }

        refreshBtn.addEventListener('click', load);
        kindSel.addEventListener('change', load);
        failuresChk.addEventListener('change', load);
        targetIn.addEventListener('keydown', (e) => { if (e.key === 'Enter') load(); });

        load();
        // Auto-refresh every 10s while the tab is open. Quiet enough
        // not to hammer the DB; fresh enough that you can use the
        // page as a live tail.
        setInterval(load, 10000);
    })();
</script>
