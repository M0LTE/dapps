@page
@model dapps.core.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Sign in — DAPPS";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #1a1a1a; color: #e0e0e0;
               display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .card { background: #2a2a2a; padding: 2rem; border-radius: 8px; min-width: 320px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.5); }
        h1 { margin: 0 0 1.5rem 0; font-size: 1.4rem; }
        label { display: block; margin-bottom: 0.5rem; }
        input[type=password] { width: 100%; padding: 0.6rem; background: #1a1a1a;
                               border: 1px solid #444; border-radius: 4px; color: #e0e0e0;
                               box-sizing: border-box; font-size: 1rem; }
        button { width: 100%; padding: 0.7rem; margin-top: 1rem; background: #4a90e2;
                 color: white; border: 0; border-radius: 4px; font-size: 1rem;
                 cursor: pointer; }
        button:hover { background: #5aa0f2; }
        .error { color: #f88; margin-top: 0.5rem; font-size: 0.9rem; }
        .hint { color: #888; margin-top: 1rem; font-size: 0.85rem; }
    </style>
</head>
<body>
    <div class="card">
        <h1>DAPPS — Sign in</h1>
        <form method="post">
            <label for="password">Sysop password</label>
            <input id="password" name="password" type="password" autofocus required />
            <button type="submit">Sign in</button>
            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="error">@Model.Error</div>
            }
        </form>
        <div class="hint">Cookie lasts 90 days, sliding. Browser-tab close keeps you signed in.</div>
    </div>
</body>
</html>
