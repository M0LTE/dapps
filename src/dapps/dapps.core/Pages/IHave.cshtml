@page
@model IHaveModel
@{
    ViewData["Title"] = $"DAPPS - manual ihave (@{Model.Options.Callsign})";
}

<header class="app-header">
    <span class="brand">
        <span class="dot"></span>
        DAPPS
        <span class="callsign">@Model.Options.Callsign</span>
        <span style="color: var(--text-muted); font-weight: 500; margin-left: 0.4rem;">→ manual ihave</span>
    </span>
    <span class="spacer"></span>
    <a href="/">dashboard</a>
    <a href="/Inbound">inbound</a>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a href="/Logout" class="signout">sign out</a>
    }
</header>

<main>
    @if (Model.FlashOk is not null)
    {
        <div class="ok-banner">@Model.FlashOk</div>
    }
    @if (Model.FlashError is not null)
    {
        <div class="err-banner">@Model.FlashError</div>
    }

    <h2>Compose</h2>
    <p class="muted-inline">
        Submits an outbound message via <code>Database.SubmitOutboundMessage</code> - same code path
        the dashboard's send-test form uses, just with every header field exposed for hand-crafting.
        Useful for debugging payload edge cases (TTL boundaries, salt collisions, fragment-threshold
        crossings) without writing an app first. Above the fragment threshold the message is split
        into N F2 fragment rows and the master id is returned.
    </p>

    <form class="inline" method="post">
        <label for="App">App</label>
        <input id="App" type="text" name="@nameof(IHaveModel.Form).@nameof(IHaveModel.IHaveForm.App)" value="@Model.Form.App" required />
        <small>Application name on the destination node - the receiver subscribes to <code>dapps/in/&lt;app&gt;</code> for this.</small>

        <label for="Destination">Destination callsign</label>
        <input id="Destination" type="text" name="@nameof(IHaveModel.Form).@nameof(IHaveModel.IHaveForm.Destination)" value="@Model.Form.Destination" required />
        <small>Includes optional SSID, e.g. <code>M0LTE-1</code>. Case-insensitive - normalised to upper-case before submit.</small>

        <label for="Payload">Payload (UTF-8 text)</label>
        <input id="Payload" type="text" name="@nameof(IHaveModel.Form).@nameof(IHaveModel.IHaveForm.Payload)" value="@Model.Form.Payload" />
        <small>UTF-8 bytes go on the wire. For binary payloads use the REST <code>/AppApi/outbound</code> endpoint.</small>

        <label for="Ttl">Residual TTL (seconds)</label>
        <input id="Ttl" type="text" name="@nameof(IHaveModel.Form).@nameof(IHaveModel.IHaveForm.TtlSeconds)" value="@Model.Form.TtlSeconds" />
        <small>Optional. Empty = no expiry; the message persists indefinitely if unforwardable. Each forwarding hop decrements by queue-dwell time and drops on zero.</small>

        <button type="submit">Submit</button>
    </form>

    @if (Model.LastSubmittedId is not null)
    {
        <h2>Last submission</h2>
        <div class="card">
            <div class="label">Message id</div>
            <div class="value mono"><code>@Model.LastSubmittedId</code></div>
            <div class="caption">
                The forwarder will pick this up on its next 5-second tick. The on-the-wire shape will look like:<br/>
                <code>@Model.LastIhavePreview</code>
            </div>
        </div>
    }
</main>
