@page
@model DiagnosticsModel
@{
    ViewData["Title"] = $"DAPPS - diagnostics ({Model.Options.Callsign})";
    ViewData["Active"] = "diagnostics";
    ViewData["PageTitle"] = "Diagnostics";
    ViewData["PageSubtitle"] = "What just transmitted, and why. Persistent log of every outbound frame this node has put on the air, plus on-demand actions.";
}

@section Actions {
    <button class="btn ghost sm" type="button" onclick="dappsRunSweep()">Probe everyone</button>
    <button class="btn ghost sm" type="button" onclick="dappsRunPollSweep()">Poll everyone</button>
}

<div class="panel">
    <h3>Transmissions audit
        <span id="tx-status" class="pill">loading</span>
    </h3>
    <p class="panel-sub">Polled from <code>/Transmissions</code>; retention controlled by <code>TransmissionAuditRetentionDays</code> (default 90). Each row carries the daemon's reason for transmitting.</p>
    <div class="row-form" style="margin-bottom: 1rem;">
        <div class="field">
            <label for="tx-kind">Kind</label>
            <select id="tx-kind">
                <option value="">all</option>
                <option value="beacon">beacon</option>
                <option value="solicit">solicit</option>
                <option value="solicit-reply">solicit-reply</option>
                <option value="probe">probe</option>
                <option value="probe-nodeprompt">probe-nodeprompt</option>
                <option value="forward">forward</option>
                <option value="forward-flood">forward-flood</option>
                <option value="poll">poll</option>
                <option value="rev-drain">rev-drain</option>
                <option value="ack">ack</option>
                <option value="nak">nak</option>
                <option value="heartbeat">heartbeat</option>
            </select>
        </div>
        <div class="field">
            <label for="tx-target">Target callsign</label>
            <input id="tx-target" type="text" placeholder="e.g. M0LTE-1" />
        </div>
        <label class="field-checkbox">
            <input id="tx-failures" type="checkbox" />
            <span>only failures</span>
        </label>
        <button class="btn ghost sm" type="button" id="tx-refresh">Refresh</button>
        <span class="muted" id="tx-count" style="font-size: 0.78rem;">-</span>
    </div>
    <table id="tx-table">
        <thead>
            <tr>
                <th style="width: 11rem;">When (UTC)</th>
                <th style="width: 9rem;">Kind</th>
                <th style="width: 4rem;">Bearer</th>
                <th style="width: 9rem;">Target</th>
                <th>Reason</th>
                <th class="numeric" style="width: 5rem;">Bytes</th>
                <th class="numeric" style="width: 5rem;">ms</th>
                <th style="width: 5rem;">OK?</th>
            </tr>
        </thead>
        <tbody id="tx-body">
            <tr><td colspan="8" class="muted" style="text-align:center;">loading</td></tr>
        </tbody>
    </table>
</div>

<script>
async function dappsPostJson(url, body, method) {
    const res = await fetch(url, {
        method: method || 'POST',
        headers: { 'content-type': 'application/json' },
        body: body == null ? null : JSON.stringify(body),
    });
    if (!res.ok && res.status !== 204) {
        const text = await res.text();
        alert(`Request failed (${res.status}): ${text}`);
        return false;
    }
    return true;
}
window.dappsRunSweep = async () => {
    if (!confirm('Probe every known peer now? Uses other operators\' airtime.')) return;
    if (await dappsPostJson('@Url.Content("~/Probes/run")', null)) await window.dappsRefreshSnap?.();
};
window.dappsRunPollSweep = async () => {
    if (!confirm('Poll every neighbour for queued mail now?')) return;
    if (await dappsPostJson('@Url.Content("~/Polls/run")', null)) await window.dappsRefreshSnap?.();
};

(function () {
    const tbody = document.getElementById('tx-body');
    const status = document.getElementById('tx-status');
    const counter = document.getElementById('tx-count');
    const kindSel = document.getElementById('tx-kind');
    const targetIn = document.getElementById('tx-target');
    const failuresChk = document.getElementById('tx-failures');
    const refreshBtn = document.getElementById('tx-refresh');

    const fmtAt = (iso) => {
        try { return new Date(iso).toISOString().replace('T', ' ').substring(0, 19); }
        catch { return iso ?? '-'; }
    };
    const escape = (s) => String(s ?? '').replace(/[&<>"']/g, c =>
        ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

    async function load() {
        status.textContent = 'loading';
        status.className = 'pill';
        const params = new URLSearchParams();
        params.set('limit', '300');
        if (kindSel.value) params.append('kind', kindSel.value);
        const t = targetIn.value.trim();
        if (t) params.set('target', t);
        if (failuresChk.checked) params.set('onlyFailures', 'true');

        try {
            const res = await fetch('@Url.Content("~/Transmissions")?' + params.toString(), { credentials: 'same-origin' });
            if (!res.ok) {
                status.textContent = 'error'; status.className = 'pill warn';
                tbody.innerHTML = `<tr><td colspan="8" class="muted" style="text-align:center;">HTTP ${res.status}</td></tr>`;
                return;
            }
            const rows = await res.json();
            status.textContent = 'live'; status.className = 'pill ok';
            counter.textContent = `${rows.length} row(s)`;
            if (rows.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" class="muted" style="text-align:center;">no transmissions match</td></tr>';
                return;
            }
            tbody.innerHTML = rows.map(r => {
                const ok = r.success
                    ? '<span class="pill ok">ok</span>'
                    : `<span class="pill err">${escape(r.errorTag || 'fail')}</span>`;
                return '<tr>'
                    + '<td>' + escape(fmtAt(r.at)) + '</td>'
                    + '<td><code>' + escape(r.kind) + '</code></td>'
                    + '<td>' + escape(r.bearer) + '</td>'
                    + '<td>' + (r.targetCallsign ? '<code>' + escape(r.targetCallsign) + '</code>' : '') + '</td>'
                    + '<td>' + escape(r.reason) + '</td>'
                    + '<td class="numeric">' + (r.bytes || '') + '</td>'
                    + '<td class="numeric">' + (r.durationMs || '') + '</td>'
                    + '<td>' + ok + '</td>'
                    + '</tr>';
            }).join('');
        } catch (e) {
            status.textContent = 'error'; status.className = 'pill warn';
            tbody.innerHTML = `<tr><td colspan="8" class="muted" style="text-align:center;">${escape(e.message ?? e)}</td></tr>`;
        }
    }
    refreshBtn.addEventListener('click', load);
    kindSel.addEventListener('change', load);
    failuresChk.addEventListener('change', load);
    targetIn.addEventListener('keydown', (e) => { if (e.key === 'Enter') load(); });
    load();
    setInterval(load, 10000);
})();
</script>
