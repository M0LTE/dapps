@page
@model IndexModel
@{
    ViewData["Title"] = $"DAPPS — {Model.Options.Callsign}";
}

<header class="app-header">
    <span class="brand">
        <span class="dot"></span>
        DAPPS
        <span class="callsign">@Model.Options.Callsign</span>
    </span>
    <span class="spacer"></span>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a href="/Logout" class="signout">Sign out</a>
    }
</header>

<main>

@if (Model.FlashOk is not null)
{
    <div class="ok-banner">@Model.FlashOk</div>
}
@if (Model.FlashError is not null)
{
    <div class="err-banner">@Model.FlashError</div>
}

<h2>Node</h2>
<div class="grid">
    <div class="card">
        <div class="label">Callsign</div>
        <div class="value mono">@Model.Options.Callsign</div>
        <div class="caption">how this node identifies itself on the air</div>
    </div>
    <div class="card">
        <div class="label">BPQ AGW</div>
        <div class="value mono">
            <span>@Model.Options.NodeHost:@Model.Options.AgwPort</span>
            <span class="dot @(Model.BpqAgwReachable ? "ok" : "warn")" title="@(Model.BpqAgwReachable ? "reachable" : "unreachable")"></span>
        </div>
        <div class="caption">
            @(Model.BpqAgwReachable ? "TCP probe ok — BPQ accepting connections" : "TCP probe failed — start linbpq or check AGWPORT")
        </div>
    </div>
    <div class="card">
        <div class="label">Default outbound port</div>
        <div class="value mono">AGW @Model.Options.DefaultBpqPort → BPQ @(Model.Options.DefaultBpqPort + 1)</div>
        <div class="caption">port byte sent on outbound forwards when a neighbour has none set</div>
    </div>
    <div class="card">
        <div class="label">MQTT broker</div>
        <div class="value mono">localhost:@Model.Options.MqttPort</div>
        <div class="caption">apps subscribe here for inbound messages (see <code>dapps/in/&lt;app&gt;</code>)</div>
    </div>
    <div class="card">
        <div class="label">UDP datagram listener</div>
        <div class="value">
            @if (Model.Options.UdpListenPort > 0)
            {
                <span class="pill info">on :@Model.Options.UdpListenPort</span>
            }
            else
            {
                <span class="pill">disabled</span>
            }
        </div>
        <div class="caption">stand-in for MeshCore-style datagram backhaul; off in normal use</div>
    </div>
    <div class="card">
        <div class="label">App-interface auth</div>
        <div class="value">
            @if (Model.Options.AuthRequired)
            {
                <span class="pill ok">tokens required</span>
            }
            else
            {
                <span class="pill warn">open</span>
            }
        </div>
        <div class="caption">
            @if (Model.Options.AuthRequired)
            {
                <span>MQTT/REST clients must present a per-app token</span>
            }
            else
            {
                <span>any MQTT/REST client on this host can act as any app — fine for loopback, set tokens for shared nodes</span>
            }
        </div>
    </div>
</div>
<details class="edit-block">
    <summary>Edit configuration</summary>
    <p class="muted">Restart required for callsign, BPQ AGW host/port, MQTT port, UDP listener port to take effect.</p>
    <form class="edit-form" onsubmit="dappsSaveConfig(event)">
        <label>Callsign <input name="Callsign" value="@Model.Options.Callsign" required /></label>
        <label>Node host <input name="NodeHost" value="@Model.Options.NodeHost" required /></label>
        <label>AGW port <input name="AgwPort" type="number" min="1" max="65535" value="@Model.Options.AgwPort" required /></label>
        <label>Default BPQ port <input name="DefaultBpqPort" type="number" min="0" max="255" value="@Model.Options.DefaultBpqPort" required /></label>
        <label>MQTT port <input name="MqttPort" type="number" min="1" max="65535" value="@Model.Options.MqttPort" required /></label>
        <label>UDP listener port (0 = disabled) <input name="UdpListenPort" type="number" min="0" max="65535" value="@Model.Options.UdpListenPort" required /></label>
        <label class="checkbox-label"><input name="AuthRequired" type="checkbox" @(Model.Options.AuthRequired ? "checked" : "") /> App-interface auth required</label>
        <button type="submit">Save</button>
    </form>
</details>
<details class="edit-block">
    <summary>Rotate admin password</summary>
    <form class="edit-form" onsubmit="dappsRotatePassword(event)">
        <label>New password <input name="password" type="password" required minlength="8" /></label>
        <button type="submit">Set</button>
    </form>
    <p class="muted">Existing session stays valid until logout or 90-day expiry — only future logins use the new password.</p>
</details>

<h2>Health</h2>
<p class="muted-inline">Process-lifetime counters + per-neighbour link state + a ring of recent forwarder / AGW / inbound-validation events. Resets on restart.</p>
<div class="grid">
    <div class="card">
        <div class="label">Forward attempts</div>
        <div class="value"><span id="m-forward-attempts">—</span></div>
        <div class="caption"><span id="m-forward-success">—</span> ok / <span id="m-forward-failure">—</span> failed</div>
    </div>
    <div class="card">
        <div class="label">TTL drops</div>
        <div class="value"><span id="m-ttl">—</span></div>
        <div class="caption">messages whose residual TTL hit zero in our queue</div>
    </div>
    <div class="card">
        <div class="label">No-route skips</div>
        <div class="value"><span id="m-noroute">—</span></div>
        <div class="caption">no neighbour / discovered peer / route-hint matched</div>
    </div>
    <div class="card">
        <div class="label">AGW reconnects</div>
        <div class="value"><span id="m-agw-reconnects">—</span></div>
        <div class="caption" id="m-agw-last">never</div>
    </div>
    <div class="card">
        <div class="label">Inbound L2 connects</div>
        <div class="value"><span id="m-inbound">—</span></div>
        <div class="caption">'C' frames dispatched to us by BPQ</div>
    </div>
    <div class="card">
        <div class="label">Hash mismatches</div>
        <div class="value"><span id="m-hash">—</span></div>
        <div class="caption">received payload whose sha1 didn't match the offered id</div>
    </div>
</div>

<h3 class="subhead">Per-neighbour link state</h3>
<table id="neigh-health-table">
    <thead>
        <tr>
            <th>Callsign</th>
            <th class="numeric">OK</th>
            <th class="numeric">Failed</th>
            <th>Last success</th>
            <th>Last failure</th>
            <th>Last error</th>
        </tr>
    </thead>
    <tbody id="neigh-health-body">
        <tr><td colspan="6" class="muted" style="text-align:center;">No forwarding activity yet.</td></tr>
    </tbody>
</table>

<h3 class="subhead">Recent activity</h3>
<table id="recent-events-table">
    <thead>
        <tr>
            <th>Time (UTC)</th>
            <th>Kind</th>
            <th>Detail</th>
        </tr>
    </thead>
    <tbody id="recent-events-body">
        <tr><td colspan="3" class="muted" style="text-align:center;">No events yet.</td></tr>
    </tbody>
</table>

<script>
    // Poll /Events/health every 5s; re-render counters, neighbour
    // table, and recent-events ring. Same DOM-swap pattern as the
    // queue tables — no full-page reload.
    (function () {
        const fmtAt = (iso) => iso ? new Date(iso).toISOString().replace('T', ' ').substring(0, 19) : '—';
        const fmtAgo = (iso) => {
            if (!iso) return '—';
            const s = Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 1000));
            if (s < 90) return `${s}s ago`;
            const m = Math.floor(s / 60);
            if (m < 90) return `${m}m ago`;
            const h = Math.floor(s / 3600);
            if (h < 36) return `${h}h ago`;
            return `${Math.floor(s / 86400)}d ago`;
        };
        const escape = (s) => String(s ?? '').replace(/[&<>"']/g, c =>
            ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
        const setText = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };

        async function poll() {
            try {
                const res = await fetch('/Events/health', { credentials: 'same-origin' });
                if (!res.ok) return;
                const d = await res.json();
                setText('m-forward-attempts', d.forwardAttempts);
                setText('m-forward-success', d.forwardSuccess);
                setText('m-forward-failure', d.forwardFailure);
                setText('m-ttl', d.ttlExpiredDrops);
                setText('m-noroute', d.noRouteSkips);
                setText('m-agw-reconnects', d.agwReconnects);
                setText('m-agw-last', d.agwLastReconnectAt ? `last ${fmtAgo(d.agwLastReconnectAt)}` : 'never');
                setText('m-inbound', d.inboundConnects);
                setText('m-hash', d.hashMismatches);

                const nbody = document.getElementById('neigh-health-body');
                if (!d.neighbours.length) {
                    nbody.innerHTML = '<tr><td colspan="6" class="muted" style="text-align:center;">No forwarding activity yet.</td></tr>';
                } else {
                    nbody.innerHTML = d.neighbours.map(n =>
                        `<tr>` +
                        `<td><code>${escape(n.callsign)}</code></td>` +
                        `<td class="numeric">${n.successCount}</td>` +
                        `<td class="numeric">${n.failureCount}</td>` +
                        `<td class="muted">${fmtAgo(n.lastSuccessAt)}</td>` +
                        `<td class="muted">${fmtAgo(n.lastFailureAt)}</td>` +
                        `<td class="muted">${escape(n.lastError ?? '—')}</td>` +
                        `</tr>`
                    ).join('');
                }

                const ebody = document.getElementById('recent-events-body');
                if (!d.recentEvents.length) {
                    ebody.innerHTML = '<tr><td colspan="3" class="muted" style="text-align:center;">No events yet.</td></tr>';
                } else {
                    ebody.innerHTML = d.recentEvents.map(e =>
                        `<tr>` +
                        `<td><code>${fmtAt(e.at).substring(11, 19)}</code></td>` +
                        `<td><span class="pill ${kindClass(e.kind)}">${escape(e.kind)}</span></td>` +
                        `<td class="muted">${escape(e.summary)}</td>` +
                        `</tr>`
                    ).join('');
                }
            } catch { /* try again next tick */ }
        }
        function kindClass(k) {
            if (k.endsWith('.ok')) return 'ok';
            if (k.endsWith('.fail') || k.endsWith('.mismatch') || k.endsWith('.expired') || k.endsWith('.none')) return 'warn';
            if (k.startsWith('agw.')) return 'info';
            return '';
        }
        poll();
        setInterval(poll, 5000);
    })();
</script>

<h2>Queue at a glance</h2>
<div class="grid">
    <div class="card">
        <div class="label">Total messages</div>
        <div class="value">@Model.TotalMessages</div>
        <div class="caption">all rows in the messages table, ever</div>
    </div>
    <div class="card">
        <div class="label">Pending outbound</div>
        <div class="value">@Model.PendingOutbound</div>
        <div class="caption">queued for forwarding to another node</div>
    </div>
    <div class="card">
        <div class="label">Undelivered local</div>
        <div class="value">@Model.UndeliveredLocal</div>
        <div class="caption">arrived for an app on this node, not yet ack'd</div>
    </div>
    <div class="card">
        <div class="label">Neighbours</div>
        <div class="value">@Model.NeighbourCount</div>
        <div class="caption">configured forwarding peers</div>
    </div>
</div>

<h2>Outbound queue <span id="outbound-count" class="pill @(Model.OutboundQueue.Count == 0 ? "" : "warn")">@Model.OutboundQueue.Count</span></h2>
<p class="muted-inline">Messages waiting to be forwarded to another node. The forwarder loop wakes periodically, picks one, and sends it via the cheapest reachable bearer. <span class="muted">Auto-refreshes every 5s.</span></p>
<table id="outbound-table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Destination</th>
            <th>From</th>
            <th class="numeric">Bytes</th>
            <th class="numeric">TTL</th>
            <th>Age</th>
        </tr>
    </thead>
    <tbody id="outbound-body">
    @if (Model.OutboundQueue.Count == 0)
    {
        <tr><td colspan="6" class="muted" style="text-align:center;">No outbound forwards in flight.</td></tr>
    }
    else
    {
        @foreach (var m in Model.OutboundQueue)
        {
            <tr>
                <td><code>@m.Id</code></td>
                <td><code>@m.Destination</code></td>
                <td><code>@m.SourceCallsign</code></td>
                <td class="numeric">@m.Payload.Length</td>
                <td class="numeric">@(m.Ttl?.ToString() ?? "—")</td>
                <td class="muted">@IndexModel.Age(m.CreatedAt)</td>
            </tr>
        }
    }
    </tbody>
</table>

<h2>Local inbox <span id="inbox-count" class="pill @(Model.LocalInbox.Count == 0 ? "" : "info")">@Model.LocalInbox.Count</span></h2>
<p class="muted-inline">Messages arrived for apps on this node, waiting for the app to ack via MQTT (<code>dapps/ack/&lt;app&gt;</code>) or REST.</p>
<table id="inbox-table">
    <thead>
        <tr>
            <th>Id</th>
            <th>App</th>
            <th>From</th>
            <th class="numeric">Bytes</th>
            <th class="numeric">TTL</th>
            <th>Age</th>
        </tr>
    </thead>
    <tbody id="inbox-body">
    @if (Model.LocalInbox.Count == 0)
    {
        <tr><td colspan="6" class="muted" style="text-align:center;">No undelivered messages for local apps.</td></tr>
    }
    else
    {
        @foreach (var m in Model.LocalInbox)
        {
            var atIdx = m.Destination.IndexOf('@');
            var app = atIdx > 0 ? m.Destination.Substring(0, atIdx) : m.Destination;
            <tr>
                <td><code>@m.Id</code></td>
                <td><code>@app</code></td>
                <td><code>@m.SourceCallsign</code></td>
                <td class="numeric">@m.Payload.Length</td>
                <td class="numeric">@(m.Ttl?.ToString() ?? "—")</td>
                <td class="muted">@IndexModel.Age(m.CreatedAt)</td>
            </tr>
        }
    }
    </tbody>
</table>

<script>
    // Poll /Events/queue every 5s and rerender just the two
    // <tbody>s + the count pills. No full-page reload — keeps
    // scroll position, open <details>, focus, etc.
    (function () {
        const fmtAge = (s) => {
            if (s < 90) return `${s}s`;
            const m = Math.floor(s / 60);
            if (m < 90) return `${m}m`;
            const h = Math.floor(s / 3600);
            if (h < 36) return `${h}h`;
            return `${Math.floor(s / 86400)}d`;
        };
        const escape = (s) => String(s).replace(/[&<>"']/g, c =>
            ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
        const render = (rows, cols) => {
            if (!rows.length) {
                return `<tr><td colspan="${cols.length}" class="muted" style="text-align:center;">empty</td></tr>`;
            }
            return rows.map(r => '<tr>' + cols.map(c => c(r)).join('') + '</tr>').join('');
        };
        const outboundCols = [
            r => `<td><code>${escape(r.id)}</code></td>`,
            r => `<td><code>${escape(r.destination)}</code></td>`,
            r => `<td><code>${escape(r.sourceCallsign)}</code></td>`,
            r => `<td class="numeric">${r.bytes}</td>`,
            r => `<td class="numeric">${r.ttl ?? '—'}</td>`,
            r => `<td class="muted">${fmtAge(r.ageSeconds)}</td>`,
        ];
        const inboxCols = [
            r => `<td><code>${escape(r.id)}</code></td>`,
            r => `<td><code>${escape(r.app)}</code></td>`,
            r => `<td><code>${escape(r.sourceCallsign)}</code></td>`,
            r => `<td class="numeric">${r.bytes}</td>`,
            r => `<td class="numeric">${r.ttl ?? '—'}</td>`,
            r => `<td class="muted">${fmtAge(r.ageSeconds)}</td>`,
        ];
        async function poll() {
            try {
                const res = await fetch('/Events/queue', { credentials: 'same-origin' });
                if (!res.ok) return;
                const d = await res.json();
                document.getElementById('outbound-body').innerHTML = render(d.outbound, outboundCols);
                document.getElementById('inbox-body').innerHTML = render(d.localInbox, inboxCols);
                const oc = document.getElementById('outbound-count');
                oc.textContent = d.outbound.length;
                oc.className = 'pill' + (d.outbound.length ? ' warn' : '');
                const ic = document.getElementById('inbox-count');
                ic.textContent = d.localInbox.length;
                ic.className = 'pill' + (d.localInbox.length ? ' info' : '');
            } catch { /* swallow; try again next tick */ }
        }
        setInterval(poll, 5000);
    })();
</script>

<h2>Neighbours</h2>
@if (Model.Neighbours.Count == 0)
{
    <p class="muted">No neighbours configured.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Callsign</th>
                <th>BPQ port</th>
                <th>UDP endpoint</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var n in Model.Neighbours)
        {
            <tr>
                <td>@n.Callsign</td>
                <td class="numeric">@(n.BpqPort?.ToString() ?? "—")</td>
                <td>@(n.UdpEndpoint ?? "—")</td>
                <td><button class="link-btn" onclick="dappsDeleteNeighbour('@n.Callsign')">remove</button></td>
            </tr>
        }
        </tbody>
    </table>
}
<details class="edit-block">
    <summary>Add neighbour</summary>
    <form class="edit-form" onsubmit="dappsAddNeighbour(event)">
        <label>Callsign <input name="callsign" required placeholder="GB7XYZ" /></label>
        <label>BPQ port <input name="bpqPort" type="number" min="0" max="255" placeholder="0" /></label>
        <label>UDP endpoint (optional) <input name="udpEndpoint" placeholder="host:port" /></label>
        <button type="submit">Add / update</button>
    </form>
</details>

<h2>Discovery channels</h2>
@if (Model.DiscoveryChannels.Count == 0)
{
    <p class="muted">No discovery channels configured.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Bearer</th>
                <th>Channel</th>
                <th>Link class</th>
                <th>Cost</th>
                <th>Beacon every</th>
                <th>Advertised TTL</th>
                <th>Enabled</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var c in Model.DiscoveryChannels)
        {
            <tr>
                <td>@c.Bearer</td>
                <td><code>@c.ChannelKey</code></td>
                <td>@c.LinkClass</td>
                <td class="numeric">@c.CostHint</td>
                <td class="numeric">@c.BeaconIntervalSeconds s</td>
                <td class="numeric">@c.AdvertisedTtlSeconds s</td>
                <td>@(c.Enabled ? "yes" : "no")</td>
                <td><button class="link-btn" onclick="dappsDeleteChannel(@c.Id)">remove</button></td>
            </tr>
        }
        </tbody>
    </table>
}
<details class="edit-block">
    <summary>Add discovery channel</summary>
    <form class="edit-form" onsubmit="dappsAddChannel(event)">
        <label>Bearer
            <select name="bearer">
                <option value="agw">agw</option>
                <option value="udp">udp</option>
            </select>
        </label>
        <label>Channel key <input name="channelKey" required placeholder="0 (BPQ port byte) or 239.0.0.1:54321" /></label>
        <label>Link class
            <select name="linkClass">
                <option>VhfUhfFm</option>
                <option>MeshCore</option>
                <option>Hf</option>
                <option>LanMulticast</option>
                <option>InternetIp</option>
            </select>
        </label>
        <button type="submit">Add / update</button>
    </form>
</details>

<h2>Discovered peers</h2>
@if (Model.DiscoveredPeers.Count == 0)
{
    <p class="muted">No peers heard yet.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Callsign</th>
                <th>Bearer</th>
                <th>Channel</th>
                <th>Link class</th>
                <th>Cost</th>
                <th>Hops</th>
                <th>Source</th>
                <th>Last seen</th>
                <th>TTL</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model.DiscoveredPeers)
        {
            <tr>
                <td>@p.Callsign</td>
                <td>@p.Bearer</td>
                <td><code>@p.ChannelKey</code></td>
                <td>@p.LinkClass</td>
                <td class="numeric">@p.CostHint</td>
                <td class="numeric">@p.Hops</td>
                <td>@(p.UdpEndpoint ?? (p.BpqPort is { } bp ? $"BPQ port {bp}" : "—"))</td>
                <td>@IndexModel.Age(p.LastSeen) ago</td>
                <td class="numeric">@p.TtlSeconds s</td>
            </tr>
        }
        </tbody>
    </table>
}

<h2>Live inbound <span id="sse-status" class="pill">connecting</span></h2>
<p class="muted">
    Server-Sent Events feed of messages arriving at this node. Clears
    on page reload — the queue tables above carry the persistent state.
</p>
<table id="sse-table">
    <thead>
        <tr>
            <th>Time (UTC)</th>
            <th>Id</th>
            <th>Source</th>
            <th>Destination</th>
            <th>Bytes</th>
            <th>TTL</th>
        </tr>
    </thead>
    <tbody id="sse-body">
        <tr id="sse-empty"><td colspan="6" class="muted">Waiting for inbound traffic…</td></tr>
    </tbody>
</table>

<script>
    (function () {
        const status = document.getElementById('sse-status');
        const body = document.getElementById('sse-body');
        const empty = document.getElementById('sse-empty');
        const es = new EventSource('/Events/inbound');
        es.onopen = () => {
            status.textContent = 'live';
            status.className = 'pill ok';
            status.innerHTML = '<span class="dot live"></span> live';
        };
        es.onerror = () => {
            status.textContent = 'reconnecting';
            status.className = 'pill warn';
        };
        es.addEventListener('inbound', (e) => {
            const ev = JSON.parse(e.data);
            if (empty) empty.remove();
            const row = document.createElement('tr');
            const ts = new Date(ev.receivedAt).toISOString().substring(11, 19);
            row.innerHTML =
                `<td><code>${ts}</code></td>` +
                `<td><code>${ev.id}</code></td>` +
                `<td>${ev.sourceCallsign}</td>` +
                `<td>${ev.destination}</td>` +
                `<td class="numeric">${ev.payloadLength}</td>` +
                `<td class="numeric">${ev.ttl ?? '—'}</td>`;
            body.insertBefore(row, body.firstChild);
            // Keep at most 50 rows so the page doesn't grow unbounded.
            while (body.children.length > 50) body.removeChild(body.lastChild);
        });
    })();
</script>

<h2>Send a test message</h2>
<p class="muted-inline">
    Drops an outbound message into the queue exactly as an app would via MQTT or REST.
    Useful for verifying a link to another node — give it the destination's <em>callsign</em>
    and the destination must have a DAPPS instance running an app with the same name (or
    just be willing to receive — apps don't need to exist for the message to land in the
    inbox).
</p>
<form class="inline" method="post" asp-page-handler="Send">
    <label for="send-app">App name</label>
    <input type="text" id="send-app" name="Send.App" value="@Model.Send.App" placeholder="chat" required />
    <small class="muted">A short identifier — e.g. <code>chat</code>, <code>weather</code>, <code>ping</code>. Apps subscribe to <code>dapps/in/&lt;name&gt;</code> on their local broker.</small>

    <label for="send-dest">Destination callsign</label>
    <input type="text" id="send-dest" name="Send.Destination" value="@Model.Send.Destination" placeholder="GB7RDG-4" required />
    <small class="muted">Where the message is going. Full callsign with SSID. Must be reachable through a configured neighbour or via routing.</small>

    <label for="send-payload">Payload</label>
    <input type="text" id="send-payload" name="Send.Payload" value="@Model.Send.Payload" placeholder="hello world" required />
    <small class="muted">Any UTF-8 text. DAPPS treats it as opaque bytes — apps decide what to do with it.</small>

    <button type="submit">Queue message</button>
</form>

<script>
    // Inline edit handlers for the configuration / neighbour / channel
    // forms. Each posts JSON to the existing controllers and reloads on
    // success — auth piggy-backs on the dapps.admin cookie the dashboard
    // is already loaded under.
    async function dappsPostJson(url, body, method) {
        const res = await fetch(url, {
            method: method || 'POST',
            headers: { 'content-type': 'application/json' },
            body: body == null ? null : JSON.stringify(body),
        });
        if (!res.ok && res.status !== 204) {
            const text = await res.text();
            alert(`Request failed (${res.status}): ${text}`);
            return false;
        }
        return true;
    }

    async function dappsSaveConfig(ev) {
        ev.preventDefault();
        const f = ev.target;
        const body = {
            Callsign: f.Callsign.value,
            NodeHost: f.NodeHost.value,
            AgwPort: parseInt(f.AgwPort.value, 10),
            DefaultBpqPort: parseInt(f.DefaultBpqPort.value, 10),
            MqttPort: parseInt(f.MqttPort.value, 10),
            UdpListenPort: parseInt(f.UdpListenPort.value, 10),
            AuthRequired: f.AuthRequired.checked,
        };
        if (await dappsPostJson('/Config', body)) location.reload();
    }

    async function dappsRotatePassword(ev) {
        ev.preventDefault();
        const pwd = ev.target.password.value;
        if (await dappsPostJson('/Config/admin-password', { password: pwd })) {
            ev.target.reset();
            alert('Password updated.');
        }
    }

    async function dappsAddNeighbour(ev) {
        ev.preventDefault();
        const f = ev.target;
        const body = {
            Callsign: f.callsign.value,
            BpqPort: f.bpqPort.value === '' ? null : parseInt(f.bpqPort.value, 10),
            UdpEndpoint: f.udpEndpoint.value || null,
        };
        if (await dappsPostJson('/Neighbours', body)) location.reload();
    }

    async function dappsDeleteNeighbour(callsign) {
        if (!confirm(`Remove neighbour ${callsign}?`)) return;
        if (await dappsPostJson('/Neighbours/' + encodeURIComponent(callsign), null, 'DELETE')) {
            location.reload();
        }
    }

    async function dappsAddChannel(ev) {
        ev.preventDefault();
        const f = ev.target;
        const body = {
            Bearer: f.bearer.value,
            ChannelKey: f.channelKey.value,
            LinkClass: f.linkClass.value,
        };
        if (await dappsPostJson('/DiscoveryChannels', body)) location.reload();
    }

    async function dappsDeleteChannel(id) {
        if (!confirm(`Remove discovery channel ${id}?`)) return;
        if (await dappsPostJson('/DiscoveryChannels/' + id, null, 'DELETE')) {
            location.reload();
        }
    }
</script>

</main>
